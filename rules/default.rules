prefix_rule(pattern=["/bin/bash", "-lc", "cat <<'EOF' > gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-altfmt-interleave.c\n/* { dg-do compile } */\n/* { dg-options \"-O2 -march=rv64gcv_zvfbfmin_zvfofp8min -mabi=lp64d\" } */\n\n#include \"riscv_vector.h\"\n\n/* These Zvfofp8min builtins are not yet declared in the testsuite header.  */\nextern vuint8mf8_t __riscv_vfncvt_f_f_w_bf16mf4_f8e4m3mf8 (vbfloat16mf4_t,\n                                                           size_t);\nextern vuint8mf8_t __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (vbfloat16mf4_t,\n                                                           size_t);\nextern vbfloat16mf4_t __riscv_vfwcvt_f_f_v_f8e4m3mf8_bf16mf4 (vuint8mf8_t,\n                                                              size_t);\n\nvuint8mf8_t\ntest_altfmt_interleave (vbfloat16mf4_t src_bf16, vuint8mf8_t src_f8, size_t vl)\n{\n  /* altfmt = 1 (f8e5m2) */\n  vuint8mf8_t alt_a = __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (src_bf16, vl);\n  asm volatile (\"\" ::: \"memory\");\n\n  /* altfmt = 0 (f8e4m3) */\n  vbfloat16mf4_t non_alt\n    = __riscv_vfwcvt_f_f_v_f8e4m3mf8_bf16mf4 (src_f8, vl);\n  asm volatile (\"\" ::: \"memory\");\n\n  /* altfmt = 1 again (f8e5m2) */\n  vuint8mf8_t alt_b\n    = __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (non_alt, vl);\n\n  return __riscv_vadd_vv_u8mf8 (alt_a, alt_b, vl);\n}\n\n/* We expect three vector configuration changes in this interleaving pattern.  */\n/* { dg-final { scan-assembler-times {vsetvli} 3 } } */\nEOF"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "cat <<'EOF' > gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-altfmt-interleave.c\n/* { dg-do compile } */\n/* { dg-options \"-O2 -march=rv64gcv_zvfbfmin_zvfofp8min -mabi=lp64d\" } */\n\n#include \"riscv_vector.h\"\n\nvuint8mf8_t\ntest_altfmt_interleave (vbfloat16mf4_t src_bf16, vuint8mf8_t src_f8, size_t vl)\n{\n  /* altfmt = 1 (f8e5m2) */\n  vuint8mf8_t alt_a = __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (src_bf16, vl);\n  asm volatile (\"# ALT-A\" ::: \"memory\");\n\n  /* altfmt = 0 (f8e4m3) */\n  vbfloat16mf4_t non_alt\n    = __riscv_vfwcvt_f_f_v_f8e4m3mf8_bf16mf4 (src_f8, vl);\n  asm volatile (\"# NONALT\" ::: \"memory\");\n\n  /* altfmt is not required here.  */\n  vuint8mf8_t dontcare = __riscv_vadd_vv_u8mf8 (alt_a, src_f8, vl);\n  asm volatile (\"# DONTCARE\" ::: \"memory\");\n\n  /* altfmt = 1 again (f8e5m2) */\n  vuint8mf8_t alt_b\n    = __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (non_alt, vl);\n  asm volatile (\"# ALT-B\" ::: \"memory\");\n\n  return __riscv_vadd_vv_u8mf8 (dontcare, alt_b, vl);\n}\n\n/* We expect three vector configuration changes in this interleaving pattern.  */\n/* { dg-final { scan-assembler-times {vsetvli} 3 } } */\n/* { dg-final { scan-assembler {# ALT-A} } } */\n/* { dg-final { scan-assembler {# NONALT} } } */\n/* { dg-final { scan-assembler {# DONTCARE} } } */\n/* { dg-final { scan-assembler {# ALT-B} } } */\nEOF"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "cat <<'EOF' > gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-altfmt-interleave.c\n/* { dg-do compile } */\n/* { dg-options \"-O2 -fno-schedule-insns -fno-schedule-insns2 -fdump-rtl-expand -march=rv64gcv_zvfbfmin_zvfofp8min -mabi=lp64d\" } */\n\n#include \"riscv_vector.h\"\n\nvuint8mf8_t\ntest_altfmt_interleave (vbfloat16mf4_t src_bf16, vuint8mf8_t src_f8, size_t vl)\n{\n  /* altfmt = 1 (f8e5m2) */\n  vuint8mf8_t alt_a = __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (src_bf16, vl);\n\n  /* altfmt = 0 (f8e4m3) */\n  vbfloat16mf4_t non_alt\n    = __riscv_vfwcvt_f_f_v_f8e4m3mf8_bf16mf4 (src_f8, vl);\n\n  /* altfmt is not required here.  */\n  vuint8mf8_t dontcare = __riscv_vadd_vv_u8mf8 (alt_a, src_f8, vl);\n\n  /* altfmt = 1 again (f8e5m2) */\n  vuint8mf8_t alt_b\n    = __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (non_alt, vl);\n\n  return __riscv_vadd_vv_u8mf8 (dontcare, alt_b, vl);\n}\n\n/* We expect three vector configuration changes in this interleaving pattern.  */\n/* { dg-final { scan-assembler-times {vsetvli} 3 } } */\n/* { dg-final { scan-rtl-dump-times {UNSPEC_F8E5M2} 2 \"expand\" } } */\n/* { dg-final { scan-rtl-dump-times {UNSPEC_F8E4M3} 1 \"expand\" } } */\n/* { dg-final { cleanup-rtl-dump \"expand\" } } */\nEOF"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "cat <<'EOF' > gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-altfmt-interleave.c\n/* { dg-do compile } */\n/* { dg-options \"-O2 -fno-schedule-insns -fno-schedule-insns2 -march=rv64gcv_zvfbfmin_zvfofp8min -mabi=lp64d\" } */\n\n#include \"riscv_vector.h\"\n\nvuint8mf8_t\ntest_altfmt_interleave (vbfloat16mf4_t src_bf16, vuint8mf8_t src_f8, size_t vl)\n{\n  /* altfmt = 1 (f8e5m2) */\n  vuint8mf8_t alt_a = __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (src_bf16, vl);\n\n  /* altfmt = 0 (f8e4m3) */\n  vbfloat16mf4_t non_alt\n    = __riscv_vfwcvt_f_f_v_f8e4m3mf8_bf16mf4 (src_f8, vl);\n\n  /* altfmt is not required here.  */\n  vuint8mf8_t dontcare = __riscv_vadd_vv_u8mf8 (alt_a, src_f8, vl);\n\n  /* altfmt = 1 again (f8e5m2) */\n  vuint8mf8_t alt_b\n    = __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (non_alt, vl);\n\n  return __riscv_vadd_vv_u8mf8 (dontcare, alt_b, vl);\n}\n\n/* We expect three vector configuration changes in this interleaving pattern.  */\n/* { dg-final { scan-assembler-times {vsetvli} 3 } } */\n/* Assume the printer can emit the alt suffix in vtype.  */\n/* { dg-final { scan-assembler-times {vsetvli\\s+[^,]+,\\s*[^,]+,\\s*e8alt,\\s*mf8} 2 } } */\n/* { dg-final { scan-assembler-times {vsetvli\\s+[^,]+,\\s*[^,]+,\\s*e8,\\s*mf8} 1 } } */\nEOF"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "cat <<'EOF' > gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-altfmt-interleave.c\n/* { dg-do compile } */\n/* { dg-options \"-O2 -fno-schedule-insns -fno-schedule-insns2 -march=rv64gcv_zvfbfmin_zvfofp8min -mabi=lp64d\" } */\n\n#include \"riscv_vector.h\"\n\nvuint8mf8_t\ntest_altfmt_interleave (vbfloat16mf4_t src_bf16, vuint8mf8_t src_f8, size_t vl)\n{\n  /* altfmt = 1 (f8e5m2) */\n  vuint8mf8_t alt_a = __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (src_bf16, vl);\n\n  /* altfmt = 0 (f8e4m3) */\n  vbfloat16mf4_t non_alt\n    = __riscv_vfwcvt_f_f_v_f8e4m3mf8_bf16mf4 (src_f8, vl);\n\n  /* altfmt is not required here.  */\n  vuint8mf8_t dontcare = __riscv_vadd_vv_u8mf8 (alt_a, src_f8, vl);\n\n  /* altfmt = 1 again (f8e5m2) */\n  vuint8mf8_t alt_b\n    = __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (non_alt, vl);\n\n  return __riscv_vadd_vv_u8mf8 (dontcare, alt_b, vl);\n}\n\n/* We expect three vector configuration changes in this interleaving pattern.  */\n/* { dg-final { scan-assembler-times {vsetvli} 3 } } */\n/* Assume the printer can emit the alt suffix in vtype.  */\n/* { dg-final { scan-assembler-times {vsetvli\\s+zero,\\s*[a-x0-9]+,\\s*e8alt,\\s*mf8,\\s*t[au],\\s*m[au]} 2 } } */\n/* { dg-final { scan-assembler-times {vsetvli\\s+zero,\\s*[a-x0-9]+,\\s*e8,\\s*mf8,\\s*t[au],\\s*m[au]} 1 } } */\nEOF"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "cat <<'EOF' > gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-altfmt-interleave.c\n/* { dg-do compile } */\n/* { dg-options \"-O2 -fno-schedule-insns -fno-schedule-insns2 -march=rv64gcv_zvfbfmin_zvfofp8min -mabi=lp64d\" } */\n\n#include \"riscv_vector.h\"\n\n/* a -> need alt.  */\n/* n -> do not need alt.  */\n/* d -> do not care alt.  */\n\nvbfloat16mf4_t\ntest_a_n_interleave (vbfloat16mf4_t src_bf16, size_t vl)\n{\n  vuint8mf8_t a = __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (src_bf16, vl);\n  return __riscv_vfwcvt_f_f_v_f8e4m3mf8_bf16mf4 (a, vl);\n}\n\nvuint8mf8_t\ntest_a_n_a_interleave (vbfloat16mf4_t src_bf16, size_t vl)\n{\n  vuint8mf8_t a0 = __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (src_bf16, vl);\n  vbfloat16mf4_t n = __riscv_vfwcvt_f_f_v_f8e4m3mf8_bf16mf4 (a0, vl);\n  return __riscv_vfncvt_f_f_w_bf16mf4_f8e5m2mf8 (n, vl);\n}\n\nvuint8mf8_t\ntest_a_n_d_interleave (vuint8mf8_t src_f8, size_t vl)\n{\n  vbfloat16mf4_t a = __riscv_vfwcvt_f_f_v_f8e5m2mf8_bf16mf4 (src_f8, vl);\n  vuint8mf8_t n = __riscv_vfncvt_f_f_w_bf16mf4_f8e4m3mf8 (a, vl);\n  return __riscv_vadd_vv_u8mf8 (n, n, vl);\n}\n\nvbfloat16mf4_t\ntest_n_a_interleave (vbfloat16mf4_t src_bf16, size_t vl)\n{\n  vuint8mf8_t n = __riscv_vfncvt_f_f_w_bf16mf4_f8e4m3mf8 (src_bf16, vl);\n  return __riscv_vfwcvt_f_f_v_f8e5m2mf8_bf16mf4 (n, vl);\n}\n\nvuint8mf8_t\ntest_n_a_n_interleave (vbfloat16mf4_t src_bf16, size_t vl)\n{\n  vuint8mf8_t n0 = __riscv_vfncvt_f_f_w_bf16mf4_f8e4m3mf8 (src_bf16, vl);\n  vbfloat16mf4_t a = __riscv_vfwcvt_f_f_v_f8e5m2mf8_bf16mf4 (n0, vl);\n  return __riscv_vfncvt_f_f_w_bf16mf4_f8e4m3mf8 (a, vl);\n}\n\n/* Assume the printer can emit the alt suffix in vtype.  */\n/* { dg-final { scan-assembler-times {vsetvli\\s+zero,\\s*[a-x0-9]+,\\s*e8alt,\\s*mf8,\\s*t[au],\\s*m[au]} 6 } } */\n/* { dg-final { scan-assembler-times {vsetvli\\s+zero,\\s*[a-x0-9]+,\\s*e8,\\s*mf8,\\s*t[au],\\s*m[au]} 6 } } */\nEOF"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/vector.md')\ntext = path.read_text()\n\nold = '''(define_attr \"has_vtype_op\" \"false,true\"\n  (cond [(eq_attr \"type\" \"vlde,vste,vldm,vstm,vlds,vsts,\\\n\\t\\t\\t  vldux,vldox,vstux,vstox,vldff,\\\n\\t\\t\\t  vialu,viwalu,vext,vicalu,vshift,vnshift,vicmp,viminmax,\\\n\\t\\t\\t  vimul,vidiv,viwmul,vimuladd,viwmuladd,vimerge,\n\\t\\t\\t  vmov,vimov,\\\n\\t\\t\\t  vsalu,vaalu,vsmul,vsshift,vnclip,\\\n\\t\\t\\t  vfalu,vfwalu,vfmul,vfdiv,vfwmul,vfmuladd,vfwmuladd,vfsqrt,vfrecp,\\\n\\t\\t\\t  vfcmp,vfminmax,vfsgnj,vfclass,vfmerge,vfmov,\\\n\\t\\t\\t  vfcvtitof,vfcvtftoi,vfwcvtitof,vfwcvtftoi,\\\n\\t\\t\\t  vfwcvtftof,vfncvtitof,vfncvtftoi,vfncvtftof,\\\n\\t\\t\\t  vired,viwred,vfredu,vfredo,vfwredu,vfwredo,vfpmad,\\\n\\t\\t\\t  vmalu,vmpop,vmffs,vmsfs,vmiota,vmidx,vimovvx,vimovxv,vfmovvf,vfmovfv,\\\n\\t\\t\\t  vslideup,vslidedown,vislide1up,vislide1down,vfslide1up,vfslide1down,\\\n\\t\\t\\t  vgather,vcompress,vlsegde,vssegte,vlsegds,vssegts,vlsegdux,vlsegdox,\\\n\\t\\t\\t  vssegtux,vssegtox,vlsegdff,vandn,vbrev,vbrev8,vrev8,vcpop,vclz,vctz,vrol,\\\n\\t\\t\\t  vror,vwsll,vclmul,vclmulh,vghsh,vgmul,vaesef,vaesem,vaesdf,vaesdm,\\\n\\t\\t\\t  vaeskf1,vaeskf2,vaesz,vsha2ms,vsha2ch,vsha2cl,vsm4k,vsm4r,vsm3me,vsm3c,\\\n\\t\\t\\t  vfncvtbf16,vfwcvtbf16,vfwmaccbf16,nds_vfncvtbf16,nds_vfwcvtbf16\")\n\\t (const_string \"true\")]\n\\t(const_string \"false\")))\n\n;; True if the type is RVV instructions that include VL\n'''\n\ninsert = '''(define_attr \"has_vtype_op\" \"false,true\"\n  (cond [(eq_attr \"type\" \"vlde,vste,vldm,vstm,vlds,vsts,\\\n\\t\\t\\t  vldux,vldox,vstux,vstox,vldff,\\\n\\t\\t\\t  vialu,viwalu,vext,vicalu,vshift,vnshift,vicmp,viminmax,\\\n\\t\\t\\t  vimul,vidiv,viwmul,vimuladd,viwmuladd,vimerge,\n\\t\\t\\t  vmov,vimov,\\\n\\t\\t\\t  vsalu,vaalu,vsmul,vsshift,vnclip,\\\n\\t\\t\\t  vfalu,vfwalu,vfmul,vfdiv,vfwmul,vfmuladd,vfwmuladd,vfsqrt,vfrecp,\\\n\\t\\t\\t  vfcmp,vfminmax,vfsgnj,vfclass,vfmerge,vfmov,\\\n\\t\\t\\t  vfcvtitof,vfcvtftoi,vfwcvtitof,vfwcvtftoi,\\\n\\t\\t\\t  vfwcvtftof,vfncvtitof,vfncvtftoi,vfncvtftof,\\\n\\t\\t\\t  vired,viwred,vfredu,vfredo,vfwredu,vfwredo,vfpmad,\\\n\\t\\t\\t  vmalu,vmpop,vmffs,vmsfs,vmiota,vmidx,vimovvx,vimovxv,vfmovvf,vfmovfv,\\\n\\t\\t\\t  vslideup,vslidedown,vislide1up,vislide1down,vfslide1up,vfslide1down,\\\n\\t\\t\\t  vgather,vcompress,vlsegde,vssegte,vlsegds,vssegts,vlsegdux,vlsegdox,\\\n\\t\\t\\t  vssegtux,vssegtox,vlsegdff,vandn,vbrev,vbrev8,vrev8,vcpop,vclz,vctz,vrol,\\\n\\t\\t\\t  vror,vwsll,vclmul,vclmulh,vghsh,vgmul,vaesef,vaesem,vaesdf,vaesdm,\\\n\\t\\t\\t  vaeskf1,vaeskf2,vaesz,vsha2ms,vsha2ch,vsha2cl,vsm4k,vsm4r,vsm3me,vsm3c,\\\n\\t\\t\\t  vfncvtbf16,vfwcvtbf16,vfwmaccbf16,nds_vfncvtbf16,nds_vfwcvtbf16\")\n\\t (const_string \"true\")]\n\\t(const_string \"false\")))\n\n;; Alternate FP8 format requirement.  Most instructions do not care.\n(define_attr \"altfmt\" \"none,alt,any\"\n  (const_string \"any\"))\n\n;; True if the type is RVV instructions that include VL\n'''\n\nif old not in text:\n    raise SystemExit('Failed to locate has_vtype_op block for altfmt insertion')\ntext = text.replace(old, insert, 1)\n\nold_vsetvl = '''(define_insn \"@vsetvl<mode>\"\n  [(set (match_operand:P 0 \"register_operand\" \"=r\")\n\\t(unspec:P [(match_operand:P 1 \"vector_length_operand\" \"rvl\")\n\\t\\t   (match_operand 2 \"const_int_operand\" \"i\")\n\\t\\t   (match_operand 3 \"const_int_operand\" \"i\")\n\\t\\t   (match_operand 4 \"const_int_operand\" \"i\")\n\\t\\t   (match_operand 5 \"const_int_operand\" \"i\")] UNSPEC_VSETVL))\n   (set (reg:SI VL_REGNUM)\n\\t(unspec:SI [(match_dup 1)\n\\t\\t    (match_dup 2)\n\\t\\t    (match_dup 3)] UNSPEC_VSETVL))\n   (set (reg:SI VTYPE_REGNUM)\n\\t(unspec:SI [(match_dup 2)\n\\t\\t    (match_dup 3)\n\\t\\t    (match_dup 4)\n\\t\\t    (match_dup 5)] UNSPEC_VSETVL))]\n  \"TARGET_VECTOR\"\n  \"vset%i1vli\\t%0,%1,e%2,%m3,t%p4,m%p5\"\n  [(set_attr \"type\" \"vsetvl\")\n   (set_attr \"mode\" \"<MODE>\")\n   (set (attr \"sew\") (symbol_ref \"INTVAL (operands[2])\"))\n   (set (attr \"vlmul\") (symbol_ref \"INTVAL (operands[3])\"))\n   (set (attr \"ta\") (symbol_ref \"INTVAL (operands[4])\"))\n   (set (attr \"ma\") (symbol_ref \"INTVAL (operands[5])\"))])\n'''\n\nnew_vsetvl = '''(define_insn \"@vsetvl<mode>\"\n  [(set (match_operand:P 0 \"register_operand\" \"=r\")\n\\t(unspec:P [(match_operand:P 1 \"vector_length_operand\" \"rvl\")\n\\t\\t   (match_operand 2 \"const_int_operand\" \"i\")\n\\t\\t   (match_operand 3 \"const_int_operand\" \"i\")\n\\t\\t   (match_operand 4 \"const_int_operand\" \"i\")\n\\t\\t   (match_operand 5 \"const_int_operand\" \"i\")\n\\t\\t   (match_operand 6 \"const_int_operand\" \"i\")] UNSPEC_VSETVL))\n   (set (reg:SI VL_REGNUM)\n\\t(unspec:SI [(match_dup 1)\n\\t\\t    (match_dup 2)\n\\t\\t    (match_dup 3)] UNSPEC_VSETVL))\n   (set (reg:SI VTYPE_REGNUM)\n\\t(unspec:SI [(match_dup 2)\n\\t\\t    (match_dup 3)\n\\t\\t    (match_dup 4)\n\\t\\t    (match_dup 5)\n\\t\\t    (match_dup 6)] UNSPEC_VSETVL))]\n  \"TARGET_VECTOR\"\n  \"* return INTVAL (operands[4])\\n\\t  ? \\\"vset%i1vli\\\\t%0,%1,e%2alt,%m3,t%p5,m%p6\\\"\\n\\t  : \\\"vset%i1vli\\\\t%0,%1,e%2,%m3,t%p5,m%p6\\\";\"\n  [(set_attr \"type\" \"vsetvl\")\n   (set_attr \"mode\" \"<MODE>\")\n   (set (attr \"sew\") (symbol_ref \"INTVAL (operands[2])\"))\n   (set (attr \"vlmul\") (symbol_ref \"INTVAL (operands[3])\"))\n   (set (attr \"altfmt\") (symbol_ref \"INTVAL (operands[4])\"))\n   (set (attr \"ta\") (symbol_ref \"INTVAL (operands[5])\"))\n   (set (attr \"ma\") (symbol_ref \"INTVAL (operands[6])\"))])\n'''\n\nif old_vsetvl not in text:\n    raise SystemExit('Failed to locate main vsetvl pattern')\ntext = text.replace(old_vsetvl, new_vsetvl, 1)\n\nold_vtype_change = '''(define_insn \"vsetvl_vtype_change_only\"\n  [(set (reg:SI VTYPE_REGNUM)\n\\t(unspec:SI\n\\t  [(match_operand 0 \"const_int_operand\" \"i\")\n\\t   (match_operand 1 \"const_int_operand\" \"i\")\n\\t   (match_operand 2 \"const_int_operand\" \"i\")\n\\t   (match_operand 3 \"const_int_operand\" \"i\")] UNSPEC_VSETVL))]\n  \"TARGET_VECTOR\"\n  \"vsetvli\\tzero,zero,e%0,%m1,t%p2,m%p3\"\n  [(set_attr \"type\" \"vsetvl\")\n   (set_attr \"mode\" \"SI\")\n   (set (attr \"sew\") (symbol_ref \"INTVAL (operands[0])\"))\n   (set (attr \"vlmul\") (symbol_ref \"INTVAL (operands[1])\"))\n   (set (attr \"ta\") (symbol_ref \"INTVAL (operands[2])\"))\n   (set (attr \"ma\") (symbol_ref \"INTVAL (operands[3])\"))])\n'''\n\nnew_vtype_change = '''(define_insn \"vsetvl_vtype_change_only\"\n  [(set (reg:SI VTYPE_REGNUM)\n\\t(unspec:SI\n\\t  [(match_operand 0 \"const_int_operand\" \"i\")\n\\t   (match_operand 1 \"const_int_operand\" \"i\")\n\\t   (match_operand 2 \"const_int_operand\" \"i\")\n\\t   (match_operand 3 \"const_int_operand\" \"i\")\n\\t   (match_operand 4 \"const_int_operand\" \"i\")] UNSPEC_VSETVL))]\n  \"TARGET_VECTOR\"\n  \"* return INTVAL (operands[2])\\n\\t  ? \\\"vsetvli\\\\tzero,zero,e%0alt,%m1,t%p3,m%p4\\\"\\n\\t  : \\\"vsetvli\\\\tzero,zero,e%0,%m1,t%p3,m%p4\\\";\"\n  [(set_attr \"type\" \"vsetvl\")\n   (set_attr \"mode\" \"SI\")\n   (set (attr \"sew\") (symbol_ref \"INTVAL (operands[0])\"))\n   (set (attr \"vlmul\") (symbol_ref \"INTVAL (operands[1])\"))\n   (set (attr \"altfmt\") (symbol_ref \"INTVAL (operands[2])\"))\n   (set (attr \"ta\") (symbol_ref \"INTVAL (operands[3])\"))\n   (set (attr \"ma\") (symbol_ref \"INTVAL (operands[4])\"))])\n'''\n\nif old_vtype_change not in text:\n    raise SystemExit('Failed to locate vsetvl_vtype_change_only pattern')\ntext = text.replace(old_vtype_change, new_vtype_change, 1)\n\nold_discard = '''(define_insn \"@vsetvl_discard_result<mode>\"\n  [(set (reg:SI VL_REGNUM)\n\\t(unspec:SI [(match_operand:P 0 \"vector_length_operand\" \"rvl\")\n\\t\\t    (match_operand 1 \"const_int_operand\" \"i\")\n\\t\\t    (match_operand 2 \"const_int_operand\" \"i\")] UNSPEC_VSETVL))\n   (set (reg:SI VTYPE_REGNU