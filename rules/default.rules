(sign_extend:DI (subreg:SI (reg:DI 134 [ _1 ]) 0)))\n;;\n;; The reason we can remove signe_extend is because currently the vl value\n;; returned by the vsetvl instruction ranges from 0 to 65536 (uint16_t), and\n;; bits 17 to 63 (including 31) are always 0, so there is no change after\n;; sign_extend. Note that for HI and QI modes we cannot do this.\n;; Of course, if the range of instructions returned by vsetvl later expands\n;; to 32bits, then this combine pattern needs to be removed. But that could be\n;; a long time from now.\n(define_insn_and_split \"*vsetvldi_no_side_effects_si_extend\"\n  [(set (match_operand:DI 0 \"register_operand\")\n        (sign_extend:DI\n          (subreg:SI\n\\t    (unspec:DI [(match_operand:P 1 \"vector_length_operand\")\n\\t\\t        (match_operand 2 \"const_int_operand\")\n\\t\\t        (match_operand 3 \"const_int_operand\")\n\\t\\t        (match_operand 4 \"const_int_operand\")\n\\t\\t        (match_operand 5 \"const_int_operand\")\n\\t\\t        (match_operand 6 \"const_int_operand\")] UNSPEC_VSETVL) 0)))]\n  \"TARGET_VECTOR && TARGET_64BIT\"\n  \"#\"\n  \"&& 1\"\n  [(set (match_dup 0)\n        (unspec:DI [(match_dup 1)\n                    (match_dup 2)\n                    (match_dup 3)\n                    (match_dup 4)\n                    (match_dup 5)\n                    (match_dup 6)] UNSPEC_VSETVL))]\n  \"\"\n  [(set_attr \"type\" \"vsetvl\")\n   (set_attr \"mode\" \"SI\")\n   (set (attr \"altfmt\") (symbol_ref \"INTVAL (operands[4])\"))])\n\n(define_insn \"@vsetvl<mode>_volatile\"\n  [(set (match_operand:P 0 \"register_operand\" \"=r\")\n\\t(unspec_volatile:P [(match_operand:P 1 \"csr_operand\" \"rK\")\n\\t\\t\\t   (match_operand 2 \"const_int_operand\" \"i\")\n\\t\\t\\t   (match_operand 3 \"const_int_operand\" \"i\")\n\\t\\t\\t   (match_operand 4 \"const_int_operand\" \"i\")\n\\t\\t\\t   (match_operand 5 \"const_int_operand\" \"i\")\n\\t\\t\\t   (match_operand 6 \"const_int_operand\" \"i\")] UNSPEC_VSETVL))\n   (set (reg:SI VL_REGNUM)\n\\t(unspec_volatile:SI [(match_dup 1)\n\\t\\t\\t    (match_dup 2)\n\\t\\t\\t    (match_dup 3)] UNSPEC_VSETVL))\n   (set (reg:SI VTYPE_REGNUM)\n\\t(unspec_volatile:SI [(match_dup 2)\n\\t\\t\\t    (match_dup 3)\n\\t\\t\\t    (match_dup 4)\n\\t\\t\\t    (match_dup 5)\n\\t\\t\\t    (match_dup 6)] UNSPEC_VSETVL))]\n  \"TARGET_VECTOR\"\n  \"* return INTVAL (operands[4])\\n\\t  ? \\\"vset%i1vli\\\\t%0,%1,e%2alt,%m3,t%p5,m%p6\\\"\\n\\t  : \\\"vset%i1vli\\\\t%0,%1,e%2,%m3,t%p5,m%p6\\\";\"\n  [(set_attr \"type\" \"vsetvl\")\n   (set_attr \"mode\" \"<MODE>\")\n   (set (attr \"sew\") (symbol_ref \"INTVAL (operands[2])\"))\n   (set (attr \"vlmul\") (symbol_ref \"INTVAL (operands[3])\"))\n   (set (attr \"altfmt\") (symbol_ref \"INTVAL (operands[4])\"))\n   (set (attr \"ta\") (symbol_ref \"INTVAL (operands[5])\"))\n   (set (attr \"ma\") (symbol_ref \"INTVAL (operands[6])\"))])\n\n'''\n\npattern = re.compile(r'\\(define_insn \"@vsetvl<mode>\".*?;; RVV machine description matching format', re.S)\nmatch = pattern.search(text)\nif not match:\n    raise SystemExit('Failed to locate vsetvl block for replacement')\nstart, end = match.span()\ntext = text[:start] + new_block + ';; RVV machine description matching format' + text[end:]\n\npath.write_text(text)\nprint('vector.md altfmt updates applied')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/vector.md')\ntext = path.read_text()\n\nrepls = [(\n'''  \"* return INTVAL (operands[4])\n\\t  ? \"vset%i1vli\\t%0,%1,e%2alt,%m3,t%p5,m%p6\"\n\\t  : \"vset%i1vli\\t%0,%1,e%2,%m3,t%p5,m%p6\";\"\n''',\n'''  \"* return INTVAL (operands[4])\\n\\t  ? \\\\\\\"vset%i1vli\\\\t%0,%1,e%2alt,%m3,t%p5,m%p6\\\\\\\"\\n\\t  : \\\\\\\"vset%i1vli\\\\t%0,%1,e%2,%m3,t%p5,m%p6\\\\\\\";\"\n'''\n),(\n'''  \"* return INTVAL (operands[2])\n\\t  ? \"vsetvli\\tzero,zero,e%0alt,%m1,t%p3,m%p4\"\n\\t  : \"vsetvli\\tzero,zero,e%0,%m1,t%p3,m%p4\";\"\n''',\n'''  \"* return INTVAL (operands[2])\\n\\t  ? \\\\\\\"vsetvli\\\\tzero,zero,e%0alt,%m1,t%p3,m%p4\\\\\\\"\\n\\t  : \\\\\\\"vsetvli\\\\tzero,zero,e%0,%m1,t%p3,m%p4\\\\\\\";\"\n'''\n),(\n'''  \"* return INTVAL (operands[3])\n\\t  ? \"vset%i0vli\\tzero,%0,e%1alt,%m2,t%p4,m%p5\"\n\\t  : \"vset%i0vli\\tzero,%0,e%1,%m2,t%p4,m%p5\";\"\n''',\n'''  \"* return INTVAL (operands[3])\\n\\t  ? \\\\\\\"vset%i0vli\\\\tzero,%0,e%1alt,%m2,t%p4,m%p5\\\\\\\"\\n\\t  : \\\\\\\"vset%i0vli\\\\tzero,%0,e%1,%m2,t%p4,m%p5\\\\\\\";\"\n'''\n),(\n'''  \"* return INTVAL (operands[4])\n\\t  ? \"vset%i1vli\\t%0,%1,e%2alt,%m3,t%p5,m%p6\"\n\\t  : \"vset%i1vli\\t%0,%1,e%2,%m3,t%p5,m%p6\";\"\n''',\n'''  \"* return INTVAL (operands[4])\\n\\t  ? \\\\\\\"vset%i1vli\\\\t%0,%1,e%2alt,%m3,t%p5,m%p6\\\\\\\"\\n\\t  : \\\\\\\"vset%i1vli\\\\t%0,%1,e%2,%m3,t%p5,m%p6\\\\\\\";\"\n'''\n)]\n\nfor old, new in repls:\n    if old not in text:\n        raise SystemExit('Expected output string block not found')\n    text = text.replace(old, new, 1)\n\npath.write_text(text)\nprint('Fixed vsetvl output string escaping')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\npath = Path('gcc/config/riscv/vector.md')\ntext = path.read_text()\n\nnew_block = r'''(define_insn \"@vsetvl<mode>\"\n  [(set (match_operand:P 0 \"register_operand\" \"=r\")\n\t(unspec:P [(match_operand:P 1 \"vector_length_operand\" \"rvl\")\n\t\t   (match_operand 2 \"const_int_operand\" \"i\")\n\t\t   (match_operand 3 \"const_int_operand\" \"i\")\n\t\t   (match_operand 4 \"const_int_operand\" \"i\")\n\t\t   (match_operand 5 \"const_int_operand\" \"i\")\n\t\t   (match_operand 6 \"const_int_operand\" \"i\")] UNSPEC_VSETVL))\n   (set (reg:SI VL_REGNUM)\n\t(unspec:SI [(match_dup 1)\n\t\t    (match_dup 2)\n\t\t    (match_dup 3)] UNSPEC_VSETVL))\n   (set (reg:SI VTYPE_REGNUM)\n\t(unspec:SI [(match_dup 2)\n\t\t    (match_dup 3)\n\t\t    (match_dup 4)\n\t\t    (match_dup 5)\n\t\t    (match_dup 6)] UNSPEC_VSETVL))]\n  \"TARGET_VECTOR\"\n  \"* return INTVAL (operands[4])\\n\\t  ? \\\"vset%i1vli\\\\t%0,%1,e%2alt,%m3,t%p5,m%p6\\\"\\n\\t  : \\\"vset%i1vli\\\\t%0,%1,e%2,%m3,t%p5,m%p6\\\";\"\n  [(set_attr \"type\" \"vsetvl\")\n   (set_attr \"mode\" \"<MODE>\")\n   (set (attr \"sew\") (symbol_ref \"INTVAL (operands[2])\"))\n   (set (attr \"vlmul\") (symbol_ref \"INTVAL (operands[3])\"))\n   (set (attr \"altfmt\") (symbol_ref \"INTVAL (operands[4])\"))\n   (set (attr \"ta\") (symbol_ref \"INTVAL (operands[5])\"))\n   (set (attr \"ma\") (symbol_ref \"INTVAL (operands[6])\"))])\n\n;; vsetvl zero,zero,vtype instruction.\n;; This pattern has no side effects and does not set X0 register.\n(define_insn \"vsetvl_vtype_change_only\"\n  [(set (reg:SI VTYPE_REGNUM)\n\t(unspec:SI\n\t  [(match_operand 0 \"const_int_operand\" \"i\")\n\t   (match_operand 1 \"const_int_operand\" \"i\")\n\t   (match_operand 2 \"const_int_operand\" \"i\")\n\t   (match_operand 3 \"const_int_operand\" \"i\")\n\t   (match_operand 4 \"const_int_operand\" \"i\")] UNSPEC_VSETVL))]\n  \"TARGET_VECTOR\"\n  \"* return INTVAL (operands[2])\\n\\t  ? \\\"vsetvli\\\\tzero,zero,e%0alt,%m1,t%p3,m%p4\\\"\\n\\t  : \\\"vsetvli\\\\tzero,zero,e%0,%m1,t%p3,m%p4\\\";\"\n  [(set_attr \"type\" \"vsetvl\")\n   (set_attr \"mode\" \"SI\")\n   (set (attr \"sew\") (symbol_ref \"INTVAL (operands[0])\"))\n   (set (attr \"vlmul\") (symbol_ref \"INTVAL (operands[1])\"))\n   (set (attr \"altfmt\") (symbol_ref \"INTVAL (operands[2])\"))\n   (set (attr \"ta\") (symbol_ref \"INTVAL (operands[3])\"))\n   (set (attr \"ma\") (symbol_ref \"INTVAL (operands[4])\"))])\n\n;; vsetvl zero,rs1,vtype instruction.\n;; The reason we need this pattern since we should avoid setting X0 register\n;; in vsetvl instruction pattern.\n(define_insn \"@vsetvl_discard_result<mode>\"\n  [(set (reg:SI VL_REGNUM)\n\t(unspec:SI [(match_operand:P 0 \"vector_length_operand\" \"rvl\")\n\t\t    (match_operand 1 \"const_int_operand\" \"i\")\n\t\t    (match_operand 2 \"const_int_operand\" \"i\")] UNSPEC_VSETVL))\n   (set (reg:SI VTYPE_REGNUM)\n\t(unspec:SI [(match_dup 1)\n\t\t    (match_dup 2)\n\t\t    (match_operand 3 \"const_int_operand\" \"i\")\n\t\t    (match_operand 4 \"const_int_operand\" \"i\")\n\t\t    (match_operand 5 \"const_int_operand\" \"i\")] UNSPEC_VSETVL))]\n  \"TARGET_VECTOR\"\n  \"* return INTVAL (operands[3])\\n\\t  ? \\\"vset%i0vli\\\\tzero,%0,e%1alt,%m2,t%p4,m%p5\\\"\\n\\t  : \\\"vset%i0vli\\\\tzero,%0,e%1,%m2,t%p4,m%p5\\\";\"\n  [(set_attr \"type\" \"vsetvl\")\n   (set_attr \"mode\" \"<MODE>\")\n   (set (attr \"sew\") (symbol_ref \"INTVAL (operands[1])\"))\n   (set (attr \"vlmul\") (symbol_ref \"INTVAL (operands[2])\"))\n   (set (attr \"altfmt\") (symbol_ref \"INTVAL (operands[3])\"))\n   (set (attr \"ta\") (symbol_ref \"INTVAL (operands[4])\"))\n   (set (attr \"ma\") (symbol_ref \"INTVAL (operands[5])\"))])\n\n;; It's emit by vsetvl/vsetvlmax intrinsics with no side effects.\n;; Since we have many optmization passes from \"expand\" to \"reload_completed\",\n;; such pattern can allow us gain benefits of these optimizations.\n(define_insn_and_split \"@vsetvl<mode>_no_side_effects\"\n  [(set (match_operand:P 0 \"register_operand\" \"=r\")\n\t(unspec:P [(match_operand:P 1 \"vector_length_operand\" \"rvl\")\n\t\t   (match_operand 2 \"const_int_operand\" \"i\")\n\t\t   (match_operand 3 \"const_int_operand\" \"i\")\n\t\t   (match_operand 4 \"const_int_operand\" \"i\")\n\t\t   (match_operand 5 \"const_int_operand\" \"i\")\n\t\t   (match_operand 6 \"const_int_operand\" \"i\")] UNSPEC_VSETVL))]\n  \"TARGET_VECTOR\"\n  \"#\"\n  \"&& epilogue_completed\"\n  [(parallel\n    [(set (match_dup 0)\n\t  (unspec:P [(match_dup 1) (match_dup 2) (match_dup 3)\n\t\t     (match_dup 4) (match_dup 5) (match_dup 6)] UNSPEC_VSETVL))\n     (set (reg:SI VL_REGNUM)\n\t  (unspec:SI [(match_dup 1) (match_dup 2) (match_dup 3)] UNSPEC_VSETVL))\n     (set (reg:SI VTYPE_REGNUM)\n\t  (unspec:SI [(match_dup 2) (match_dup 3) (match_dup 4)\n\t\t      (match_dup 5) (match_dup 6)] UNSPEC_VSETVL))])]\n  \"\"\n  [(set_attr \"type\" \"vsetvl\")\n   (set_attr \"mode\" \"SI\")\n   (set (attr \"altfmt\") (symbol_ref \"INTVAL (operands[4])\"))])\n\n;; This pattern use to combine bellow two insns and then further remove\n;; unnecessary sign_extend operations:\n;;   (set (reg:DI 134 [ _1 ])\n;;        (unspec:DI [\n;;                (const_int 19 [0x13])\n;;                (const_int 8 [0x8])\n;;                (const_int 5 [0x5])\n;;                (const_int 2 [0x2]) repeated x2\n;;            ] UNSPEC_VSETVL))\n;;   (set (reg/v:DI 135 [ <retval> ])\n;;           (sign_extend:DI (subreg:SI (reg:DI 134 [ _1 ]) 0)))\n;;\n;; The reason we can remove signe_extend is because currently the vl value\n;; returned by the vsetvl instruction ranges from 0 to 65536 (uint16_t), and\n;; bits 17 to 63 (including 31) are always 0, so there is no change after\n;; sign_extend. Note that for HI and QI modes we cannot do this.\n;; Of course, if the range of instructions returned by vsetvl later expands\n;; to 32bits, then this combine pattern needs to be removed. But that could be\n;; a long time from now.\n(define_insn_and_split \"*vsetvldi_no_side_effects_si_extend\"\n  [(set (match_operand:DI 0 \"register_operand\")\n        (sign_extend:DI\n          (subreg:SI\n\t    (unspec:DI [(match_operand:P 1 \"vector_length_operand\")\n\t\t        (match_operand 2 \"const_int_operand\")\n\t\t        (match_operand 3 \"const_int_operand\")\n\t\t        (match_operand 4 \"const_int_operand\")\n\t\t        (match_operand 5 \"const_int_operand\")\n\t\t        (match_operand 6 \"const_int_operand\")] UNSPEC_VSETVL) 0)))]\n  \"TARGET_VECTOR && TARGET_64BIT\"\n  \"#\"\n  \"&& 1\"\n  [(set (match_dup 0)\n        (unspec:DI [(match_dup 1)\n                    (match_dup 2)\n                    (match_dup 3)\n                    (match_dup 4)\n                    (match_dup 5)\n                    (match_dup 6)] UNSPEC_VSETVL))]\n  \"\"\n  [(set_attr \"type\" \"vsetvl\")\n   (set_attr \"mode\" \"SI\")\n   (set (attr \"altfmt\") (symbol_ref \"INTVAL (operands[4])\"))])\n\n(define_insn \"@vsetvl<mode>_volatile\"\n  [(set (match_operand:P 0 \"register_operand\" \"=r\")\n\t(unspec_volatile:P [(match_operand:P 1 \"csr_operand\" \"rK\")\n\t\t\t   (match_operand 2 \"const_int_operand\" \"i\")\n\t\t\t   (match_operand 3 \"const_int_operand\" \"i\")\n\t\t\t   (match_operand 4 \"const_int_operand\" \"i\")\n\t\t\t   (match_operand 5 \"const_int_operand\" \"i\")\n\t\t\t   (match_operand 6 \"const_int_operand\" \"i\")] UNSPEC_VSETVL))\n   (set (reg:SI VL_REGNUM)\n\t(unspec_volatile:SI [(match_dup 1)\n\t\t\t    (match_dup 2)\n\t\t\t    (match_dup 3)] UNSPEC_VSETVL))\n   (set (reg:SI VTYPE_REGNUM)\n\t(unspec_volatile:SI [(match_dup 2)\n\t\t\t    (match_dup 3)\n\t\t\t    (match_dup 4)\n\t\t\t    (match_dup 5)\n\t\t\t    (match_dup 6)] UNSPEC_VSETVL))]\n  \"TARGET_VECTOR\"\n  \"* return INTVAL (operands[4])\\n\\t  ? \\\"vset%i1vli\\\\t%0,%1,e%2alt,%m3,t%p5,m%p6\\\"\\n\\t  : \\\"vset%i1vli\\\\t%0,%1,e%2,%m3,t%p5,m%p6\\\";\"\n  [(set_attr \"type\" \"vsetvl\")\n   (set_attr \"mode\" \"<MODE>\")\n   (set (attr \"sew\") (symbol_ref \"INTVAL (operands[2])\"))\n   (set (attr \"vlmul\") (symbol_ref \"INTVAL (operands[3])\"))\n   (set (attr \"altfmt\") (symbol_ref \"INTVAL (operands[4])\"))\n   (set (attr \"ta\") (symbol_ref \"INTVAL (operands[5])\"))\n   (set (attr \"ma\") (symbol_ref \"INTVAL (operands[6])\"))])\n\n'''\n\npattern = re.compile(r'\\(define_insn \"@vsetvl<mode>\".*?;; RVV machine description matching format', re.S)\nmatch = pattern.search(text)\nif not match:\n    raise SystemExit('Failed to locate vsetvl block for replacement')\nstart, end = match.span()\ntext = text[:start] + new_block + ';; RVV machine description matching format' + text[end:]\n\npath.write_text(text)\nprint('Rebuilt vsetvl block with proper escaping')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/vector.md')\ntext = path.read_text()\nold = ''';; operands[2]: SEW\n;; operands[3]: LMUL\n;; operands[4]: Tail policy 0 or 1 (undisturbed/agnostic)\n;; operands[5]: Mask policy 0 or 1 (undisturbed/agnostic)\n'''\nnew = ''';; operands[2]: SEW\n;; operands[3]: LMUL\n;; operands[4]: ALTFMT (0: none, 1: alt)\n;; operands[5]: Tail policy 0 or 1 (undisturbed/agnostic)\n;; operands[6]: Mask policy 0 or 1 (undisturbed/agnostic)\n'''\nif old not in text:\n    raise SystemExit('Operand comment block not found')\npath.write_text(text.replace(old, new, 1))\nprint('Updated vsetvl operand comments')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/vector-float8.md')\ntext = path.read_text()\n\nmarker = '''(define_int_attr sat\n  [(UNSPEC_F8E4M3     \"\")\n   (UNSPEC_F8E5M2     \"\")\n   (UNSPEC_F8E4M3_SAT \".sat\")\n   (UNSPEC_F8E5M2_SAT \".sat\")])\n\n'''\naltfmt_kind = '''(define_int_attr sat\n  [(UNSPEC_F8E4M3     \"\")\n   (UNSPEC_F8E5M2     \"\")\n   (UNSPEC_F8E4M3_SAT \".sat\")\n   (UNSPEC_F8E5M2_SAT \".sat\")])\n\n(define_int_attr altfmt_kind\n  [(UNSPEC_F8E4M3     \"none\")\n   (UNSPEC_F8E5M2     \"alt\")\n   (UNSPEC_F8E4M3_SAT \"none\")\n   (UNSPEC_F8E5M2_SAT \"alt\")])\n\n'''\nif altfmt_kind not in text:\n    if marker not in text:\n        raise SystemExit('Failed to find sat attribute block')\n    text = text.replace(marker, altfmt_kind, 1)\n\nrepls = [\n    ('''  [(set_attr \"type\" \"vfwcvtbf16\")\n   (set_attr \"mode\" \"<MODE>\")])\n''',\n     '''  [(set_attr \"type\" \"vfwcvtbf16\")\n   (set_attr \"mode\" \"<MODE>\")\n   (set_attr \"altfmt\" \"<altfmt_kind>\")])\n'''),\n    ('''  [(set_attr \"type\" \"vfncvtbf16\")\n   (set_attr \"mode\" \"<VBF_DOUBLE_TRUNC>\")\n   (set (attr \"frm_mode\")\n   (symbol_ref \"riscv_vector::get_frm_mode (operands[8])\"))])\n''',\n     '''  [(set_attr \"type\" \"vfncvtbf16\")\n   (set_attr \"mode\" \"<VBF_DOUBLE_TRUNC>\")\n   (set_attr \"altfmt\" \"<altfmt_kind>\")\n   (set (attr \"frm_mode\")\n   (symbol_ref \"riscv_vector::get_frm_mode (operands[8])\"))])\n'''),\n    ('''  [(set_attr \"type\" \"vfncvtbf16\")\n   (set_attr \"mode\" \"<VF_QUAD_TRUNC>\")\n   (set (attr \"frm_mode\")\n   (symbol_ref \"riscv_vector::get_frm_mode (operands[8])\"))])\n''',\n     '''  [(set_attr \"type\" \"vfncvtbf16\")\n   (set_attr \"mode\" \"<VF_QUAD_TRUNC>\")\n   (set_attr \"altfmt\" \"<altfmt_kind>\")\n   (set (attr \"frm_mode\")\n   (symbol_ref \"riscv_vector::get_frm_mode (operands[8])\"))])\n''')\n]\n\nfor old, new in repls:\n    if old not in text:\n        raise SystemExit('Expected attribute block not found')\n    text = text.replace(old, new, 1)\n\npath.write_text(text)\nprint('vector-float8.md updated with altfmt attr')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.def')\ntext = path.read_text()\n\nmacro_marker = '''#ifndef DEF_POLICY_RULE\n#define DEF_POLICY_RULE(prev_demand, next_demand, fused_demand, compatible_p,  \\\n\\t\\t\\tavailable_p, fuse)\n#endif\n\n#ifndef DEF_AVL_RULE\n#define DEF_AVL_RULE(prev_demand, next_demand, fused_demand, compatible_p,     \\\n\\t\\t     available_p, fuse)\n#endif\n\n'''\nmacro_insert = '''#ifndef DEF_POLICY_RULE\n#define DEF_POLICY_RULE(prev_demand, next_demand, fused_demand, compatible_p,  \\\n\\t\\t\\tavailable_p, fuse)\n#endif\n\n#ifndef DEF_ALTFMT_RULE\n#define DEF_ALTFMT_RULE(prev_demand, next_demand, fused_demand, compatible_p,  \\\n\\t\\t\\tavailable_p, fuse)\n#endif\n\n#ifndef DEF_AVL_RULE\n#define DEF_AVL_RULE(prev_demand, next_demand, fused_demand, compatible_p,     \\\n\\t\\t     available_p, fuse)\n#endif\n\n'''\nif macro_insert not in text:\n    if macro_marker not in text:\n        raise SystemExit('Failed to locate macro block')\n    text = text.replace(macro_marker, macro_insert, 1)\n\naltfmt_rules = '''/* Define ALTFMT compatible and merge rules.  */\n\nDEF_ALTFMT_RULE (altfmt, altfmt, altfmt, altfmt_eq_p, altfmt_eq_p, nop)\nDEF_ALTFMT_RULE (altfmt, ignore_altfmt, altfmt, always_true, always_true, nop)\nDEF_ALTFMT_RULE (ignore_altfmt, altfmt, altfmt, always_true, always_false,\n\\t\\t use_next_altfmt)\nDEF_ALTFMT_RULE (ignore_altfmt, ignore_altfmt, ignore_altfmt, always_true,\n\\t\\t always_true, nop)\n\n'''\nif altfmt_rules not in text:\n    marker = '/* Define AVL compatible and merge rules.  */\\n\\n'\n    if marker not in text:\n        raise SystemExit('Failed to locate AVL rule marker')\n    text = text.replace(marker, altfmt_rules + marker, 1)\n\nif '#undef DEF_ALTFMT_RULE\\n' not in text:\n    text = text.replace('#undef DEF_POLICY_RULE\\n#undef DEF_AVL_RULE\\n',\n                        '#undef DEF_POLICY_RULE\\n#undef DEF_ALTFMT_RULE\\n#undef DEF_AVL_RULE\\n',\n                        1)\n\npath.write_text(text)\nprint('riscv-vsetvl.def updated with altfmt rules')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\npath = Path('gcc/config/riscv/riscv-vsetvl.def')\ntext = path.read_text()\n\n# Insert DEF_ALTFMT_RULE macro after DEF_POLICY_RULE.\nmacro_pat = re.compile(r'(#ifndef DEF_POLICY_RULE\\n#define DEF_POLICY_RULE\\(prev_demand, next_demand, fused_demand, compatible_p,  \\\\\\n\\t\\t\\tavailable_p, fuse\\)\\n#endif\\n\\n)(#ifndef DEF_AVL_RULE)', re.M)\nif not macro_pat.search(text):\n    raise SystemExit('Policy macro block not found')\ntext = macro_pat.sub(r\"\\1#ifndef DEF_ALTFMT_RULE\\n#define DEF_ALTFMT_RULE(prev_demand, next_demand, fused_demand, compatible_p,  \\\\\\n\\t\\t\\tavailable_p, fuse)\\n#endif\\n\\n\\2\", text, count=1)\n\n# Insert ALTFMT rules before AVL rules section.\naltfmt_rules = '''/* Define ALTFMT compatible and merge rules.  */\n\nDEF_ALTFMT_RULE (altfmt, altfmt, altfmt, altfmt_eq_p, altfmt_eq_p, nop)\nDEF_ALTFMT_RULE (altfmt, ignore_altfmt, altfmt, always_true, always_true, nop)\nDEF_ALTFMT_RULE (ignore_altfmt, altfmt, altfmt, always_true, always_false,\n\\t\\t use_next_altfmt)\nDEF_ALTFMT_RULE (ignore_altfmt, ignore_altfmt, ignore_altfmt, always_true,\n\\t\\t always_true, nop)\n\n'''\navl_marker = '/* Define AVL compatible and merge rules.  */\\n\\n'\nif altfmt_rules not in text:\n    if avl_marker not in text:\n        raise SystemExit('AVL marker not found')\n    text = text.replace(avl_marker, altfmt_rules + avl_marker, 1)\n\n# Undefine DEF_ALTFMT_RULE at end.\nif '#undef DEF_ALTFMT_RULE\\n' not in text:\n    text = text.replace('#undef DEF_POLICY_RULE\\n#undef DEF_AVL_RULE\\n',\n                        '#undef DEF_POLICY_RULE\\n#undef DEF_ALTFMT_RULE\\n#undef DEF_AVL_RULE\\n',\n                        1)\n\npath.write_text(text)\nprint('Updated riscv-vsetvl.def with altfmt rules')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\nold = '''static const char *\npolicy_to_str (bool agnostic_p)\n{\n  return agnostic_p ? \"agnostic\" : \"undisturbed\";\n}\n\n'''\nnew = '''static const char *\npolicy_to_str (bool agnostic_p)\n{\n  return agnostic_p ? \"agnostic\" : \"undisturbed\";\n}\n\nstatic const char *\naltfmt_to_str (uint8_t altfmt)\n{\n  switch (altfmt)\n    {\n    case ALTFMT_NONE:\n      return \"none\";\n    case ALTFMT_ALT:\n      return \"alt\";\n    case ALTFMT_ANY:\n      return \"any\";\n    default:\n      return \"unknown\";\n    }\n}\n\n'''\nif old not in text:\n    raise SystemExit('policy_to_str block not found')\npath.write_text(text.replace(old, new, 1))\nprint('Inserted altfmt_to_str helper')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\nold = '''static bool\nmask_agnostic_p (rtx_insn *rinsn)\n{\n  /* If it doesn't have MA, we return agnostic by default.  */\n  extract_insn_cached (rinsn);\n  int ma = get_attr_ma (rinsn);\n  return ma == INVALID_ATTRIBUTE ? get_default_ma () : IS_AGNOSTIC (ma);\n}\n\n'''\nnew = '''static bool\nmask_agnostic_p (rtx_insn *rinsn)\n{\n  /* If it doesn't have MA, we return agnostic by default.  */\n  extract_insn_cached (rinsn);\n  int ma = get_attr_ma (rinsn);\n  return ma == INVALID_ATTRIBUTE ? get_default_ma () : IS_AGNOSTIC (ma);\n}\n\nstatic uint8_t\nget_altfmt (rtx_insn *rinsn)\n{\n  extract_insn_cached (rinsn);\n  int altfmt = get_attr_altfmt (rinsn);\n  return altfmt == INVALID_ATTRIBUTE ? ALTFMT_NONE : altfmt;\n}\n\n'''\nif old not in text:\n    raise SystemExit('mask_agnostic_p block not found')\npath.write_text(text.replace(old, new, 1))\nprint('Inserted get_altfmt helper')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\n\nold_flags = '''  DEMAND_AVL_P = 1 << 6,\n  DEMAND_NON_ZERO_AVL_P = 1 << 7,\n};\n\n'''\nnew_flags = '''  DEMAND_AVL_P = 1 << 6,\n  DEMAND_NON_ZERO_AVL_P = 1 << 7,\n  DEMAND_ALTFMT_P = 1 << 8,\n};\n\n'''\nif old_flags not in text:\n    raise SystemExit('demand_flags block not found')\ntext = text.replace(old_flags, new_flags, 1)\n\nold_comment = '''/* We split the demand information into three parts. They are sew and lmul\n   related (sew_lmul_demand_type), tail and mask policy related\n   (policy_demand_type) and avl related (avl_demand_type). Then we define three\n   interfaces avaiable_with, compatible_p and merge. avaiable_with is\n   used to determine whether the two vsetvl infos prev_info and next_info are\n   available or not. If prev_info is available for next_info, it means that the\n   RVV insn corresponding to next_info on the path from prev_info to next_info\n   can be used without inserting a separate vsetvl instruction. compatible_p\n   is used to determine whether prev_info is compatible with next_info, and if\n   so, merge can be used to merge the stricter demand information from\n   next_info into prev_info so that prev_info becomes available to next_info.\n */\n\n'''\nnew_comment = '''/* We split the demand information into four parts. They are sew and lmul\n   related (sew_lmul_demand_type), tail and mask policy related\n   (policy_demand_type), alternate FP8 format related (altfmt_demand_type)\n   and avl related (avl_demand_type). Then we define compatible_p, available_p\n   and merge. available_p is used to determine whether the two vsetvl infos\n   prev_info and next_info are available or not. If prev_info is available for\n   next_info, it means that the RVV insn corresponding to next_info on the path\n   from prev_info to next_info can be used without inserting a separate vsetvl\n   instruction. compatible_p is used to determine whether prev_info is\n   compatible with next_info, and if so, merge can be used to merge the\n   stricter demand information from next_info into prev_info so that prev_info\n   becomes available to next_info.\n */\n\n'''\nif old_comment not in text:\n    raise SystemExit('demand comment block not found')\ntext = text.replace(old_comment, new_comment, 1)\n\npolicy_enum = '''enum class policy_demand_type : unsigned\n{\n  tail_mask_policy\n  = demand_flags::DEMAND_TAIL_POLICY_P | demand_flags::DEMAND_MASK_POLICY_P,\n  tail_policy_only = demand_flags::DEMAND_TAIL_POLICY_P,\n  mask_policy_only = demand_flags::DEMAND_MASK_POLICY_P,\n  ignore_policy = demand_flags::DEMAND_EMPTY_P,\n};\n\nenum class avl_demand_type : unsigned\n{\n  avl = demand_flags::DEMAND_AVL_P,\n  non_zero_avl = demand_flags::DEMAND_NON_ZERO_AVL_P,\n  ignore_avl = demand_flags::DEMAND_EMPTY_P,\n};\n\n'''\naltfmt_enum = '''enum class policy_demand_type : unsigned\n{\n  tail_mask_policy\n  = demand_flags::DEMAND_TAIL_POLICY_P | demand_flags::DEMAND_MASK_POLICY_P,\n  tail_policy_only = demand_flags::DEMAND_TAIL_POLICY_P,\n  mask_policy_only = demand_flags::DEMAND_MASK_POLICY_P,\n  ignore_policy = demand_flags::DEMAND_EMPTY_P,\n};\n\nenum class altfmt_demand_type : unsigned\n{\n  altfmt = demand_flags::DEMAND_ALTFMT_P,\n  ignore_altfmt = demand_flags::DEMAND_EMPTY_P,\n};\n\nenum class avl_demand_type : unsigned\n{\n  avl = demand_flags::DEMAND_AVL_P,\n  non_zero_avl = demand_flags::DEMAND_NON_ZERO_AVL_P,\n  ignore_avl = demand_flags::DEMAND_EMPTY_P,\n};\n\n'''\nif policy_enum not in text:\n    raise SystemExit('policy/avl enum block not found')\ntext = text.replace(policy_enum, altfmt_enum, 1)\n\npath.write_text(text)\nprint('Updated demand flags, comment, and altfmt demand type')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\n\nfields_old = '''  vlmul_type m_vlmul;\n  uint8_t m_ratio;\n  bool m_ta;\n  bool m_ma;\n\n  sew_lmul_demand_type m_sew_lmul_demand;\n  policy_demand_type m_policy_demand;\n  avl_demand_type m_avl_demand;\n'''\nfields_new = '''  vlmul_type m_vlmul;\n  uint8_t m_ratio;\n  uint8_t m_altfmt;\n  bool m_ta;\n  bool m_ma;\n\n  sew_lmul_demand_type m_sew_lmul_demand;\n  policy_demand_type m_policy_demand;\n  altfmt_demand_type m_altfmt_demand;\n  avl_demand_type m_avl_demand;\n'''\nif fields_old not in text:\n    raise SystemExit('vsetvl_info fields block not found')\ntext = text.replace(fields_old, fields_new, 1)\n\ninit_old = '''      m_avl_def (nullptr), m_sew (0), m_max_sew (0), m_vlmul (LMUL_RESERVED),\n      m_ratio (0), m_ta (false), m_ma (false),\n      m_sew_lmul_demand (sew_lmul_demand_type::sew_lmul),\n      m_policy_demand (policy_demand_type::tail_mask_policy),\n      m_avl_demand (avl_demand_type::avl), m_state (state_type::UNINITIALIZED),\n'''\ninit_new = '''      m_avl_def (nullptr), m_sew (0), m_max_sew (0), m_vlmul (LMUL_RESERVED),\n      m_ratio (0), m_altfmt (ALTFMT_NONE), m_ta (false), m_ma (false),\n      m_sew_lmul_demand (sew_lmul_demand_type::sew_lmul),\n      m_policy_demand (policy_demand_type::tail_mask_policy),\n      m_altfmt_demand (altfmt_demand_type::altfmt),\n      m_avl_demand (avl_demand_type::avl), m_state (state_type::UNINITIALIZED),\n'''\nif init_old not in text:\n    raise SystemExit('vsetvl_info initializer block not found')\ntext = text.replace(init_old, init_new, 1)\n\npath.write_text(text)\nprint('Updated vsetvl_info fields and initializer for altfmt')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\nold_set = '''  void set_vlmul (vlmul_type vlmul) { m_vlmul = vlmul; }\n  void set_ratio (uint8_t ratio) { m_ratio = ratio; }\n  void set_ta (bool ta) { m_ta = ta; }\n'''\nnew_set = '''  void set_vlmul (vlmul_type vlmul) { m_vlmul = vlmul; }\n  void set_ratio (uint8_t ratio) { m_ratio = ratio; }\n  void set_altfmt (uint8_t altfmt) { m_altfmt = altfmt; }\n  void set_ta (bool ta) { m_ta = ta; }\n'''\nif old_set not in text:\n    raise SystemExit('Setter block not found')\ntext = text.replace(old_set, new_set, 1)\n\nold_get = '''  vlmul_type get_vlmul () const { return m_vlmul; }\n  uint8_t get_ratio () const { return m_ratio; }\n  bool get_ta () const { return m_ta; }\n'''\nnew_get = '''  vlmul_type get_vlmul () const { return m_vlmul; }\n  uint8_t get_ratio () const { return m_ratio; }\n  uint8_t get_altfmt () const { return m_altfmt; }\n  bool get_ta () const { return m_ta; }\n'''\nif old_get not in text:\n    raise SystemExit('Getter block not found')\ntext = text.replace(old_get, new_get, 1)\n\npath.write_text(text)\nprint('Added altfmt setters/getters')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\n\nold_set = '''  void set_policy_demand (policy_demand_type demand)\n  {\n    m_policy_demand = demand;\n  }\n  void set_avl_demand (avl_demand_type demand) { m_avl_demand = demand; }\n\n  sew_lmul_demand_type get_sew_lmul_demand () const\n  {\n    return m_sew_lmul_demand;\n  }\n  policy_demand_type get_policy_demand () const { return m_policy_demand; }\n  avl_demand_type get_avl_demand () const { return m_avl_demand; }\n\n'''\nnew_set = '''  void set_policy_demand (policy_demand_type demand)\n  {\n    m_policy_demand = demand;\n  }\n  void set_altfmt_demand (altfmt_demand_type demand)\n  {\n    m_altfmt_demand = demand;\n  }\n  void set_avl_demand (avl_demand_type demand) { m_avl_demand = demand; }\n\n  sew_lmul_demand_type get_sew_lmul_demand () const\n  {\n    return m_sew_lmul_demand;\n  }\n  policy_demand_type get_policy_demand () const { return m_policy_demand; }\n  altfmt_demand_type get_altfmt_demand () const { return m_altfmt_demand; }\n  avl_demand_type get_avl_demand () const { return m_avl_demand; }\n\n'''\nif old_set not in text:\n    raise SystemExit('Demand setter/getter block not found')\npath.write_text(text.replace(old_set, new_set, 1))\nprint('Added altfmt demand setters/getters')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\nold = '''    switch (demand_flags & (DEMAND_TAIL_POLICY_P | DEMAND_MASK_POLICY_P))\n      {\n      case (unsigned) policy_demand_type::tail_mask_policy:\n\\tm_policy_demand = policy_demand_type::tail_mask_policy;\n\\tbreak;\n      case (unsigned) policy_demand_type::tail_policy_only:\n\\tm_policy_demand = policy_demand_type::tail_policy_only;\n\\tbreak;\n      case (unsigned) policy_demand_type::mask_policy_only:\n\\tm_policy_demand = policy_demand_type::mask_policy_only;\n\\tbreak;\n      case (unsigned) policy_demand_type::ignore_policy:\n\\tm_policy_demand = policy_demand_type::ignore_policy;\n\\tbreak;\n      default:\n\\tgcc_unreachable ();\n      }\n\n    switch (demand_flags & (DEMAND_AVL_P | DEMAND_NON_ZERO_AVL_P))\n      {\n'''\nnew = '''    switch (demand_flags & (DEMAND_TAIL_POLICY_P | DEMAND_MASK_POLICY_P))\n      {\n      case (unsigned) policy_demand_type::tail_mask_policy:\n\\tm_policy_demand = policy_demand_type::tail_mask_policy;\n\\tbreak;\n      case (unsigned) policy_demand_type::tail_policy_only:\n\\tm_policy_demand = policy_demand_type::tail_policy_only;\n\\tbreak;\n      case (unsigned) policy_demand_type::mask_policy_only:\n\\tm_policy_demand = policy_demand_type::mask_policy_only;\n\\tbreak;\n      case (unsigned) policy_demand_type::ignore_policy:\n\\tm_policy_demand = policy_demand_type::ignore_policy;\n\\tbreak;\n      default:\n\\tgcc_unreachable ();\n      }\n\n    switch (demand_flags & DEMAND_ALTFMT_P)\n      {\n      case (unsigned) altfmt_demand_type::altfmt:\n\\tm_altfmt_demand = altfmt_demand_type::altfmt;\n\\tbreak;\n      case (unsigned) altfmt_demand_type::ignore_altfmt:\n\\tm_altfmt_demand = altfmt_demand_type::ignore_altfmt;\n\\tbreak;\n      default:\n\\tgcc_unreachable ();\n      }\n\n    switch (demand_flags & (DEMAND_AVL_P | DEMAND_NON_ZERO_AVL_P))\n      {\n'''\nif old not in text:\n    raise SystemExit('Failed to locate normalize_demand policy->avl switch boundary')\npath.write_text(text.replace(old, new, 1))\nprint('Inserted altfmt normalization switch')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\n\n# parse_insn (rtx_insn *) altfmt\nold_rtx = '''    m_sew = ::get_sew (rinsn);\n    m_vlmul = ::get_vlmul (rinsn);\n    m_ta = tail_agnostic_p (rinsn);\n    m_ma = mask_agnostic_p (rinsn);\n'''\nnew_rtx = '''    m_sew = ::get_sew (rinsn);\n    m_vlmul = ::get_vlmul (rinsn);\n    m_altfmt = ::get_altfmt (rinsn);\n    m_ta = tail_agnostic_p (rinsn);\n    m_ma = mask_agnostic_p (rinsn);\n'''\nif old_rtx not in text:\n    raise SystemExit('parse_insn(rtx) block not found')\ntext = text.replace(old_rtx, new_rtx, 1)\n\n# parse_insn (insn_info *) altfmt\nold_info = '''    m_vlmul = ::get_vlmul (insn->rtl ());\n    m_ratio = get_attr_ratio (insn->rtl ());\n    /* when get_attr_ratio is invalid, this kind of instructions\n       doesn't care about ratio. However, we still need this value\n       in demand info backward analysis.  */\n    if (m_ratio == INVALID_ATTRIBUTE)\n      m_ratio = calculate_ratio (m_sew, m_vlmul);\n    m_ta = tail_agnostic_p (insn->rtl ());\n    m_ma = mask_agnostic_p (insn->rtl ());\n'''\nnew_info = '''    m_vlmul = ::get_vlmul (insn->rtl ());\n    m_ratio = get_attr_ratio (insn->rtl ());\n    /* when get_attr_ratio is invalid, this kind of instructions\n       doesn't care about ratio. However, we still need this value\n       in demand info backward analysis.  */\n    if (m_ratio == INVALID_ATTRIBUTE)\n      m_ratio = calculate_ratio (m_sew, m_vlmul);\n    m_altfmt = ::get_altfmt (insn->rtl ());\n    m_ta = tail_agnostic_p (insn->rtl ());\n    m_ma = mask_agnostic_p (insn->rtl ());\n'''\nif old_info not in text:\n    raise SystemExit('parse_insn(insn_info) ratio/policy block not found')\ntext = text.replace(old_info, new_info, 1)\n\n# Insert altfmt demand flag before normalize_demand.\nneedle = '\\n    normalize_demand (dflags);\\n'\nif needle not in text:\n    raise SystemExit('normalize_demand call not found')\ntext = text.replace(needle, '\\n    if (m_altfmt != ALTFMT_ANY)\\n      dflags |= demand_flags::DEMAND_ALTFMT_P;\\n\\n    normalize_demand (dflags);\\n', 1)\n\npath.write_text(text)\nprint('Updated parse_insn altfmt handling and demand flag')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\nold = '''    rtx sew = gen_int_mode (get_sew (), Pmode);\n    rtx vlmul = gen_int_mode (get_vlmul (), Pmode);\n    rtx ta = gen_int_mode (get_ta (), Pmode);\n    rtx ma = gen_int_mode (get_ma (), Pmode);\n\n    if (change_vtype_only_p ())\n      return gen_vsetvl_vtype_change_only (sew, vlmul, ta, ma);\n    else if (has_vl () && !ignore_vl)\n      return gen_vsetvl (Pmode, get_vl (), avl, sew, vlmul, ta, ma);\n    else\n      return gen_vsetvl_discard_result (Pmode, avl, sew, vlmul, ta, ma);\n'''\nnew = '''    rtx sew = gen_int_mode (get_sew (), Pmode);\n    rtx vlmul = gen_int_mode (get_vlmul (), Pmode);\n    uint8_t altfmt_val = get_altfmt () == ALTFMT_ALT ? ALTFMT_ALT : ALTFMT_NONE;\n    rtx altfmt = gen_int_mode (altfmt_val, Pmode);\n    rtx ta = gen_int_mode (get_ta (), Pmode);\n    rtx ma = gen_int_mode (get_ma (), Pmode);\n\n    if (change_vtype_only_p ())\n      return gen_vsetvl_vtype_change_only (sew, vlmul, altfmt, ta, ma);\n    else if (has_vl () && !ignore_vl)\n      return gen_vsetvl (Pmode, get_vl (), avl, sew, vlmul, altfmt, ta, ma);\n    else\n      return gen_vsetvl_discard_result (Pmode, avl, sew, vlmul, altfmt, ta, ma);\n'''\nif old not in text:\n    raise SystemExit('get_vsetvl_pat block not found')\npath.write_text(text.replace(old, new, 1))\nprint('Updated get_vsetvl_pat with altfmt operand')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\nold_vtype = '''\\t   && get_sew () == other.get_sew ()\n\\t   && get_vlmul () == other.get_vlmul () && get_ta () == other.get_ta ()\n\\t   && get_ma () == other.get_ma ()\n'''\nnew_vtype = '''\\t   && get_sew () == other.get_sew ()\n\\t   && get_vlmul () == other.get_vlmul ()\n\\t   && get_altfmt () == other.get_altfmt () && get_ta () == other.get_ta ()\n\\t   && get_ma () == other.get_ma ()\n'''\nif old_vtype not in text:\n    raise SystemExit('operator== vtype block not found')\ntext = text.replace(old_vtype, new_vtype, 1)\n\nold_dem = '''\\t   && get_avl_demand () == other.get_avl_demand ()\n\\t   && get_sew_lmul_demand () == other.get_sew_lmul_demand ()\n\\t   && get_policy_demand () == other.get_policy_demand ();\n'''\nnew_dem = '''\\t   && get_avl_demand () == other.get_avl_demand ()\n\\t   && get_sew_lmul_demand () == other.get_sew_lmul_demand ()\n\\t   && get_policy_demand () == other.get_policy_demand ()\n\\t   && get_altfmt_demand () == other.get_altfmt_demand ();\n'''\nif old_dem not in text:\n    raise SystemExit('operator== demand block not found')\ntext = text.replace(old_dem, new_dem, 1)\n\npath.write_text(text)\nprint('Updated operator== with altfmt comparisons')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\n\nold_dem = '''    if (m_policy_demand == policy_demand_type::tail_mask_policy)\n      fprintf (file, \" demand_tail_mask_policy\");\n    else if (m_policy_demand == policy_demand_type::tail_policy_only)\n      fprintf (file, \" demand_tail_policy_only\");\n    else if (m_policy_demand == policy_demand_type::mask_policy_only)\n      fprintf (file, \" demand_mask_policy_only\");\n\n    if (m_avl_demand == avl_demand_type::avl)\n      fprintf (file, \" demand_avl\");\n'''\nnew_dem = '''    if (m_policy_demand == policy_demand_type::tail_mask_policy)\n      fprintf (file, \" demand_tail_mask_policy\");\n    else if (m_policy_demand == policy_demand_type::tail_policy_only)\n      fprintf (file, \" demand_tail_policy_only\");\n    else if (m_policy_demand == policy_demand_type::mask_policy_only)\n      fprintf (file, \" demand_mask_policy_only\");\n\n    if (m_altfmt_demand == altfmt_demand_type::altfmt)\n      fprintf (file, \" demand_altfmt\");\n\n    if (m_avl_demand == avl_demand_type::avl)\n      fprintf (file, \" demand_avl\");\n'''\nif old_dem not in text:\n    raise SystemExit('Dump demand block not found')\ntext = text.replace(old_dem, new_dem, 1)\n\nold_vtype = '''    fprintf (file, \"%sSEW=%d, \", indent, get_sew ());\n    fprintf (file, \"VLMUL=%s, \", vlmul_to_str (get_vlmul ()));\\n    fprintf (file, \"RATIO=%d, \", get_ratio ());\n'''\nnew_vtype = '''    fprintf (file, \"%sSEW=%d, \", indent, get_sew ());\n    fprintf (file, \"VLMUL=%s, \", vlmul_to_str (get_vlmul ()));\\n    fprintf (file, \"ALTFMT=%s, \", altfmt_to_str (get_altfmt ()));\\n    fprintf (file, \"RATIO=%d, \", get_ratio ());\n'''\nif old_vtype not in text:\n    raise SystemExit('Dump vtype block not found')\ntext = text.replace(old_vtype, new_vtype, 1)\n\npath.write_text(text)\nprint('Updated dump output with altfmt info')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\nold = '''  inline bool tail_mask_policy_eq_p (const vsetvl_info &prev,\n\\t\\t\\t     const vsetvl_info &next)\n  {\n    return tail_policy_eq_p (prev, next) && mask_policy_eq_p (prev, next);\n  }\n\n  /* predictors for avl */\n'''\nnew = '''  inline bool tail_mask_policy_eq_p (const vsetvl_info &prev,\n\\t\\t\\t     const vsetvl_info &next)\n  {\n    return tail_policy_eq_p (prev, next) && mask_policy_eq_p (prev, next);\n  }\n\n  /* predictors for altfmt */\n\n  inline bool altfmt_eq_p (const vsetvl_info &prev, const vsetvl_info &next)\n  {\n    return prev.get_altfmt () == next.get_altfmt ();\n  }\n\n  /* predictors for avl */\n'''\nif old not in text:\n    raise SystemExit('Failed to locate tail_mask_policy_eq_p boundary')\npath.write_text(text.replace(old, new, 1))\nprint('Inserted altfmt_eq_p predictor')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\nold = '''  {\n    return tail_policy_eq_p (prev, next) && mask_policy_eq_p (prev, next);\n  }\n\n  /* predictors for avl */\n'''\nnew = '''  {\n    return tail_policy_eq_p (prev, next) && mask_policy_eq_p (prev, next);\n  }\n\n  /* predictors for altfmt */\n\n  inline bool altfmt_eq_p (const vsetvl_info &prev, const vsetvl_info &next)\n  {\n    return prev.get_altfmt () == next.get_altfmt ();\n  }\n\n  /* predictors for avl */\n'''\nif old not in text:\n    raise SystemExit('Predictor boundary not found')\npath.write_text(text.replace(old, new, 1))\nprint('Inserted altfmt predictor block')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\nold = '''  inline void use_tail_mask_policy (vsetvl_info &prev, const vsetvl_info &next)\n  {\n    use_tail_policy (prev, next);\n    use_mask_policy (prev, next);\n  }\n\n  /* modifiers for avl */\n'''\nnew = '''  inline void use_tail_mask_policy (vsetvl_info &prev, const vsetvl_info &next)\n  {\n    use_tail_policy (prev, next);\n    use_mask_policy (prev, next);\n  }\n\n  /* modifiers for altfmt */\n\n  inline void use_next_altfmt (vsetvl_info &prev, const vsetvl_info &next)\n  {\n    prev.set_altfmt (next.get_altfmt ());\n  }\n\n  /* modifiers for avl */\n'''\nif old not in text:\n    raise SystemExit('Policy->avl modifier boundary not found')\npath.write_text(text.replace(old, new, 1))\nprint('Inserted altfmt modifier block')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\nboundary = '''    gcc_unreachable ();\n  }\n\n  bool vl_not_in_conflict_p (const vsetvl_info &prev, const vsetvl_info &next)\n'''\ninsert = '''    gcc_unreachable ();\n  }\n\n  bool altfmt_compatible_p (const vsetvl_info &prev, const vsetvl_info &next)\n  {\n    gcc_assert (prev.valid_p () && next.valid_p ());\n    altfmt_demand_type prev_flags = prev.get_altfmt_demand ();\n    altfmt_demand_type next_flags = next.get_altfmt_demand ();\n#define DEF_ALTFMT_RULE(PREV_FLAGS, NEXT_FLAGS, NEW_FLAGS, COMPATIBLE_P,      \\\n\\t\\t\\tAVAILABLE_P, FUSE)                                    \\\n  if (prev_flags == altfmt_demand_type::PREV_FLAGS                             \\\n      && next_flags == altfmt_demand_type::NEXT_FLAGS)                         \\\n    return COMPATIBLE_P (prev, next);\n\n#include \"riscv-vsetvl.def\"\n\n    gcc_unreachable ();\n  }\n\n  bool altfmt_available_p (const vsetvl_info &prev, const vsetvl_info &next)\n  {\n    gcc_assert (prev.valid_p () && next.valid_p ());\n    altfmt_demand_type prev_flags = prev.get_altfmt_demand ();\n    altfmt_demand_type next_flags = next.get_altfmt_demand ();\n#define DEF_ALTFMT_RULE(PREV_FLAGS, NEXT_FLAGS, NEW_FLAGS, COMPATIBLE_P,      \\\n\\t\\t\\tAVAILABLE_P, FUSE)                                    \\\n  if (prev_flags == altfmt_demand_type::PREV_FLAGS                             \\\n      && next_flags == altfmt_demand_type::NEXT_FLAGS)                         \\\n    return AVAILABLE_P (prev, next);\n\n#include \"riscv-vsetvl.def\"\n\n    gcc_unreachable ();\n  }\n\n  void merge_altfmt (vsetvl_info &prev, const vsetvl_info &next)\n  {\n    gcc_assert (prev.valid_p () && next.valid_p ());\n    altfmt_demand_type prev_flags = prev.get_altfmt_demand ();\n    altfmt_demand_type next_flags = next.get_altfmt_demand ();\n#define DEF_ALTFMT_RULE(PREV_FLAGS, NEXT_FLAGS, NEW_FLAGS, COMPATIBLE_P,      \\\n\\t\\t\\tAVAILABLE_P, FUSE)                                    \\\n  if (prev_flags == altfmt_demand_type::PREV_FLAGS                             \\\n      && next_flags == altfmt_demand_type::NEXT_FLAGS)                         \\\n    {                                                                          \\\n      gcc_assert (COMPATIBLE_P (prev, next));                                  \\\n      FUSE (prev, next);                                                       \\\n      prev.set_altfmt_demand (altfmt_demand_type::NEW_FLAGS);                  \\\n      return;                                                                  \\\n    }\n\n#include \"riscv-vsetvl.def\"\n\n    gcc_unreachable ();\n  }\n\n  bool vl_not_in_conflict_p (const vsetvl_info &prev, const vsetvl_info &next)\n'''\nif boundary not in text:\n    raise SystemExit('Failed to locate merge_policy boundary')\npath.write_text(text.replace(boundary, insert, 1))\nprint('Inserted altfmt compatibility/availability/merge functions')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\n\nnew_block = '''bool altfmt_compatible_p (const vsetvl_info &prev, const vsetvl_info &next)\n  {\n    gcc_assert (prev.valid_p () && next.valid_p ());\n    altfmt_demand_type prev_flags = prev.get_altfmt_demand ();\n    altfmt_demand_type next_flags = next.get_altfmt_demand ();\n#define DEF_ALTFMT_RULE(PREV_FLAGS, NEXT_FLAGS, NEW_FLAGS, COMPATIBLE_P,       \\\\\n\\t\\t\\tAVAILABLE_P, FUSE)                                     \\\\\n  if (prev_flags == altfmt_demand_type::PREV_FLAGS                             \\\\\n      && next_flags == altfmt_demand_type::NEXT_FLAGS)                         \\\\\n    return COMPATIBLE_P (prev, next);\n\n#include \"riscv-vsetvl.def\"\n\n    gcc_unreachable ();\n  }\n\n  bool altfmt_available_p (const vsetvl_info &prev, const vsetvl_info &next)\n  {\n    gcc_assert (prev.valid_p () && next.valid_p ());\n    altfmt_demand_type prev_flags = prev.get_altfmt_demand ();\n    altfmt_demand_type next_flags = next.get_altfmt_demand ();\n#define DEF_ALTFMT_RULE(PREV_FLAGS, NEXT_FLAGS, NEW_FLAGS, COMPATIBLE_P,       \\\\\n\\t\\t\\tAVAILABLE_P, FUSE)                                     \\\\\n  if (prev_flags == altfmt_demand_type::PREV_FLAGS                             \\\\\n      && next_flags == altfmt_demand_type::NEXT_FLAGS)                         \\\\\n    return AVAILABLE_P (prev, next);\n\n#include \"riscv-vsetvl.def\"\n\n    gcc_unreachable ();\n  }\n\n  void merge_altfmt (vsetvl_info &prev, const vsetvl_info &next)\n  {\n    gcc_assert (prev.valid_p () && next.valid_p ());\n    altfmt_demand_type prev_flags = prev.get_altfmt_demand ();\n    altfmt_demand_type next_flags = next.get_altfmt_demand ();\n#define DEF_ALTFMT_RULE(PREV_FLAGS, NEXT_FLAGS, NEW_FLAGS, COMPATIBLE_P,       \\\\\n\\t\\t\\tAVAILABLE_P, FUSE)                                     \\\\\n  if (prev_flags == altfmt_demand_type::PREV_FLAGS                             \\\\\n      && next_flags == altfmt_demand_type::NEXT_FLAGS)                         \\\\\n    {                                                                          \\\\\n      gcc_assert (COMPATIBLE_P (prev, next));                                  \\\\\n      FUSE (prev, next);                                                       \\\\\n      prev.set_altfmt_demand (altfmt_demand_type::NEW_FLAGS);                  \\\\\n      return;                                                                  \\\\\n    }\n\n#include \"riscv-vsetvl.def\"\n\n    gcc_unreachable ();\n  }\n\n  bool vl_not_in_conflict_p (const vsetvl_info &prev, const vsetvl_info &next)\n'''\n\npattern = re.compile(r'bool altfmt_compatible_p \\(const vsetvl_info &prev, const vsetvl_info &next\\).*?bool vl_not_in_conflict_p \\(const vsetvl_info &prev, const vsetvl_info &next\\)\\n', re.S)\nif not pattern.search(text):\n    raise SystemExit('Current altfmt block not found for replacement')\ntext = pattern.sub(new_block, text, count=1)\n\npath.write_text(text)\nprint('Repaired altfmt compatibility block formatting')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\nold = '    m_altfmt = ::get_altfmt (rinsn);\\n    m_ta = tail_agnostic_p (rinsn);\\n'\nnew = '    m_altfmt = ::get_altfmt (rinsn);\\n    m_altfmt_demand = m_altfmt == ALTFMT_ANY\\n      ? altfmt_demand_type::ignore_altfmt\\n      : altfmt_demand_type::altfmt;\\n    m_ta = tail_agnostic_p (rinsn);\\n'\nif old not in text:\n    raise SystemExit('parse_insn(rtx) altfmt line not found')\npath.write_text(text.replace(old, new, 1))\nprint('Updated parse_insn(rtx) altfmt demand')\nPY"], decision="allow")
