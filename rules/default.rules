prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\npath = Path('gcc/config/riscv/riscv-v.cc')\ntext = path.read_text()\n\n# Patch emit_hard_vlmax_vsetvl call.\npat1 = re.compile(r'emit_insn \\(gen_vsetvl \\(Pmode, vl, RVV_VLMAX, gen_int_mode \\(sew, Pmode\\),\\n\\s*gen_int_mode \\(get_vlmul \\(vmode\\), Pmode\\), const0_rtx,\\n\\s*const0_rtx\\)\\);')\nrep1 = ('emit_insn (gen_vsetvl (Pmode, vl, RVV_VLMAX, gen_int_mode (sew, Pmode),\\n'\n        '\\t\\t\\t gen_int_mode (get_vlmul (vmode), Pmode),\\n'\n        '\\t\\t\\t gen_int_mode (ALTFMT_NONE, Pmode), const0_rtx, const0_rtx));')\ntext, n1 = pat1.subn(rep1, text, count=1)\nif n1 != 1:\n    raise SystemExit(f'emit_hard_vlmax_vsetvl patch failed ({n1})')\n\n# Patch gen_no_side_effects_vsetvl_rtx call.\npat2 = re.compile(r'return gen_vsetvl_no_side_effects \\(Pmode, vl, avl, gen_int_mode \\(sew, Pmode\\),\\n\\s*gen_int_mode \\(get_vlmul \\(vmode\\), Pmode\\),\\n\\s*tail_policy, mask_policy\\);')\nrep2 = ('return gen_vsetvl_no_side_effects (Pmode, vl, avl, gen_int_mode (sew, Pmode),\\n'\n        '\\t\\t\\t     gen_int_mode (get_vlmul (vmode), Pmode),\\n'\n        '\\t\\t\\t     gen_int_mode (ALTFMT_NONE, Pmode), tail_policy,\\n'\n        '\\t\\t\\t     mask_policy);')\ntext, n2 = pat2.subn(rep2, text, count=1)\nif n2 != 1:\n    raise SystemExit(f'gen_no_side_effects_vsetvl_rtx patch failed ({n2})')\n\npath.write_text(text)\nprint('Patched riscv-v.cc via regex')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-v.cc')\ntext = path.read_text()\nold = '''  return gen_vsetvl_no_side_effects (Pmode, vl, avl, gen_int_mode (sew, Pmode),\n\\t\\t     gen_int_mode (get_vlmul (vmode), Pmode),\n\\t\\t     gen_int_mode (ALTFMT_NONE, Pmode), tail_policy,\n\\t\\t     mask_policy);\n'''\nnew = '''  return gen_vsetvl_no_side_effects (Pmode, vl, avl, gen_int_mode (sew, Pmode),\n\\t\\t\\t     gen_int_mode (get_vlmul (vmode), Pmode),\n\\t\\t\\t     gen_int_mode (ALTFMT_NONE, Pmode),\n\\t\\t\\t     tail_policy, mask_policy);\n'''\nif old not in text:\n    raise SystemExit('Current gen_vsetvl_no_side_effects block not found')\npath.write_text(text.replace(old, new, 1))\nprint('Formatted gen_vsetvl_no_side_effects call')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-v.cc')\ntext = path.read_text()\nold = '''  return gen_vsetvl_no_side_effects (Pmode, vl, avl, gen_int_mode (sew, Pmode),\n\\t\\t     gen_int_mode (get_vlmul (vmode), Pmode),\n\\t\\t     gen_int_mode (ALTFMT_NONE, Pmode), tail_policy,\n\\t\\t     mask_policy);\n'''\nif old not in text:\n    old = '''  return gen_vsetvl_no_side_effects (Pmode, vl, avl, gen_int_mode (sew, Pmode),\n\\t\\t     gen_int_mode (get_vlmul (vmode), Pmode),\n\\t\\t     gen_int_mode (ALTFMT_NONE, Pmode), tail_policy,\n\\t\\t     mask_policy);\n'''\nnew = '''  return gen_vsetvl_no_side_effects (Pmode, vl, avl, gen_int_mode (sew, Pmode),\n\\t\\t\\t     gen_int_mode (get_vlmul (vmode), Pmode),\n\\t\\t\\t     gen_int_mode (ALTFMT_NONE, Pmode),\n\\t\\t\\t     tail_policy, mask_policy);\n'''\nif old not in text:\n    # Fallback: replace the exact current block with spaces.\n    old = '''  return gen_vsetvl_no_side_effects (Pmode, vl, avl, gen_int_mode (sew, Pmode),\n\\t\\t     gen_int_mode (get_vlmul (vmode), Pmode),\n\\t\\t     gen_int_mode (ALTFMT_NONE, Pmode), tail_policy,\n\\t\\t     mask_policy);\n'''\nif old not in text:\n    # Another fallback using spaces from the file.\n    old = '''  return gen_vsetvl_no_side_effects (Pmode, vl, avl, gen_int_mode (sew, Pmode),\n\\t\\t     gen_int_mode (get_vlmul (vmode), Pmode),\n\\t\\t     gen_int_mode (ALTFMT_NONE, Pmode), tail_policy,\n\\t\\t     mask_policy);\n'''\n# Directly replace the visible spaced block.\nold_visible = '''  return gen_vsetvl_no_side_effects (Pmode, vl, avl, gen_int_mode (sew, Pmode),\n\\t\\t     gen_int_mode (get_vlmul (vmode), Pmode),\n\\t\\t     gen_int_mode (ALTFMT_NONE, Pmode), tail_policy,\n\\t\\t     mask_policy);\n'''\nold_spaces = '''  return gen_vsetvl_no_side_effects (Pmode, vl, avl, gen_int_mode (sew, Pmode),\n\\t\\t     gen_int_mode (get_vlmul (vmode), Pmode),\n\\t\\t     gen_int_mode (ALTFMT_NONE, Pmode), tail_policy,\n\\t\\t     mask_policy);\n'''\nif old_visible in text:\n    text = text.replace(old_visible, new, 1)\nelif old_spaces in text:\n    text = text.replace(old_spaces, new, 1)\nelse:\n    # Use a regex fallback.\n    import re\n    pat = re.compile(r'return gen_vsetvl_no_side_effects \\(Pmode, vl, avl, gen_int_mode \\(sew, Pmode\\),\\n\\s*gen_int_mode \\(get_vlmul \\(vmode\\), Pmode\\),\\n\\s*gen_int_mode \\(ALTFMT_NONE, Pmode\\), tail_policy,\\n\\s*mask_policy\\);')\n    text, n = pat.subn(new.strip(), text, count=1)\n    if n != 1:\n        raise SystemExit('Failed to reformat gen_vsetvl_no_side_effects call')\n\npath.write_text(text)\nprint('Reformatted gen_vsetvl_no_side_effects call')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vector-builtins-bases.cc')\ntext = path.read_text()\n\n# Add insn-attr.h include after insn-codes.h.\ninc_old = '#include \"insn-codes.h\"\\n'\ninc_new = '#include \"insn-codes.h\"\\n#include \"insn-attr.h\"\\n'\nif inc_new not in text:\n    if inc_old not in text:\n        raise SystemExit('insn-codes include not found')\n    text = text.replace(inc_old, inc_new, 1)\n\n# Insert ALTFMT_NONE operand before tail/mask policies.\nmarker = '''    /* TAIL_ANY.  */\n    e.add_input_operand (Pmode,\n\\t\\t\\t gen_int_mode (get_prefer_tail_policy (), Pmode));\n\n'''\ninsert = '''    /* ALTFMT_NONE.  */\n    e.add_input_operand (Pmode, gen_int_mode (ALTFMT_NONE, Pmode));\n\n    /* TAIL_ANY.  */\n    e.add_input_operand (Pmode,\n\\t\\t\\t gen_int_mode (get_prefer_tail_policy (), Pmode));\n\n'''\nif insert not in text:\n    if marker not in text:\n        raise SystemExit('TAIL_ANY marker not found')\n    text = text.replace(marker, insert, 1)\n\npath.write_text(text)\nprint('Updated builtins bases with altfmt operand')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-v.cc')\ntext = path.read_text()\nold = \"\"\"  return gen_vsetvl_no_side_effects (Pmode, vl, avl, gen_int_mode (sew, Pmode),\n\t\t\t     gen_int_mode (get_vlmul (vmode), Pmode),\n\t\t\t     gen_int_mode (ALTFMT_NONE, Pmode),\n\t\t\t     tail_policy, mask_policy);\n\"\"\"\nnew = \"\"\"  return gen_vsetvl_no_side_effects (Pmode, vl, avl,\n\t\t\t     gen_int_mode (sew, Pmode),\n\t\t\t     gen_int_mode (get_vlmul (vmode), Pmode),\n\t\t\t     gen_int_mode (ALTFMT_NONE, Pmode),\n\t\t\t     tail_policy, mask_policy);\n\"\"\"\nif old not in text:\n    raise SystemExit('Expected block not found; aborting to avoid unintended edits.')\npath.write_text(text.replace(old, new))\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('gcc/config/riscv/riscv-vsetvl.cc')\ntext = path.read_text()\nold = '''\\tif (!prev_info.valid_p ()\n\\t    || !m_dem.avl_available_p (prev_info, curr_info)\n\\t    || prev_info.get_ratio () != curr_info.get_ratio ())\n\\t  return false;\n'''\nnew = '''\\tif (!prev_info.valid_p ()\n\\t    || !m_dem.avl_available_p (prev_info, curr_info)\n\\t    || !m_dem.altfmt_available_p (prev_info, curr_info)\n\\t    || prev_info.get_ratio () != curr_info.get_ratio ())\n\\t  return false;\n'''\nif old not in text:\n    raise SystemExit('preds_all_same_avl_and_ratio_p block not found')\npath.write_text(text.replace(old, new, 1))\nprint('Updated preds_all_same_avl_and_ratio_p with altfmt availability')\nPY"], decision="allow")
