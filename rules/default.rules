prefix_rule(pattern=["rsync", "-a", "--delete", "/fast-playground2/linopeng/my-project/zvfofp8min-test/zvfofp8min-testsuite/", "gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite/"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "perl -pi -e 's/#include <riscv_vector\\.h>/#include \"riscv_vector.h\"/g' $(rg --files -g\"*.c\" gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite)\nperl -pi -e 's/\\s*-Wno-psabi//g; s/\\s*-fno-schedule-insns2?//g' $(rg --files -g\"*.c\" gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite)\n"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\n\nroot = Path('gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite')\nfiles = list(root.rglob('vfncvt.c'))\n\nfor path in files:\n    text = path.read_text()\n    lines = text.splitlines(keepends=True)\n    # Keep header (up to and including first blank line after includes)\n    kept = []\n    i = 0\n    # Keep initial comments and includes\n    while i < len(lines):\n        kept.append(lines[i])\n        if lines[i].strip() == '' and any('#include' in l for l in kept):\n            i += 1\n            break\n        i += 1\n    # Split remaining content into blocks separated by blank lines\n    blocks = []\n    block = []\n    for line in lines[i:]:\n        if line.strip() == '':\n            if block:\n                blocks.append(block)\n                block = []\n            else:\n                # preserve extra blank lines\n                blocks.append(['\\n'])\n        else:\n            block.append(line)\n    if block:\n        blocks.append(block)\n\n    def is_fp8_block(b):\n        s = ''.join(b)\n        return ('f8e4m3' in s) or ('f8e5m2' in s)\n\n    # Keep only fp8 blocks, but preserve blank lines between kept blocks\n    new_blocks = []\n    for b in blocks:\n        if b == ['\\n']:\n            new_blocks.append(b)\n            continue\n        if is_fp8_block(b):\n            new_blocks.append(b)\n        else:\n            # drop non-fp8 block\n            pass\n\n    # Clean up consecutive blank-only blocks\n    out_lines = kept\n    prev_blank = False\n    for b in new_blocks:\n        if b == ['\\n']:\n            if not prev_blank:\n                out_lines.append('\\n')\n                prev_blank = True\n            continue\n        out_lines.extend(b)\n        prev_blank = False\n\n    # Ensure single trailing newline\n    out = ''.join(out_lines)\n    if not out.endswith('\\n'):\n        out += '\\n'\n\n    path.write_text(out)\n\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "perl -pi -e 's/rv64gcv_zvfh_zvfbfmin_zvfofp8min/rv64gcv_zvfh_zvfofp8min/g' $(rg --files -g\"vfncvt.c\" gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite)\nrg -n -e \"-march=rv64gcv_zvfh_zvfofp8min\" gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite -g\"vfncvt.c\" | head -n 4"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\nroot = Path('gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite')\n# Update dg-options\nfor path in root.rglob('*.c'):\n    text = path.read_text()\n    if 'dg-options' not in text:\n        continue\n    if path.name == 'vfncvt.c':\n        text = text.replace('rv64gcv_zvfh_zvfbfmin_zvfofp8min', 'rv64gcv_zvfh_zvfofp8min')\n        text = text.replace('rv64gcv_zvfh', 'rv64gcv_zvfh_zvfofp8min')\n    elif path.name in ('vfncvtbf16.c', 'vfwcvtbf16.c'):\n        text = text.replace('rv64gcv_zvfh', 'rv64gcv_zvfh_zvfbfmin_zvfofp8min')\n    path.write_text(text)\n\n# Update scan-assembler regex to accept e8alt\nfor path in root.rglob('*.c'):\n    text = path.read_text()\n    if 'scan-assembler' not in text:\n        continue\n    text = text.replace('e[0-9]+,', 'e[0-9]+(alt)?,')\n    path.write_text(text)\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npaths = list(Path('gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite').rglob('vfncvt.c'))\nfor path in paths:\n    lines = path.read_text().splitlines()\n    out = []\n    for i, line in enumerate(lines):\n        out.append(line)\n        if line.strip() == '}' and i + 1 < len(lines):\n            nxt = lines[i + 1]\n            if nxt.startswith('v'):\n                out.append('')\n    path.write_text('\\n'.join(out) + '\\n')\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\nfiles = [\n    Path('gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite/non-policy/non-overloaded/vfncvt.c'),\n    Path('gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite/non-policy/overloaded/vfncvt.c'),\n    Path('gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite/non-policy/non-overloaded/vfncvtbf16.c'),\n    Path('gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite/non-policy/overloaded/vfncvtbf16.c'),\n]\nfor p in files:\n    text = p.read_text()\n    func_count = len(re.findall(r'^\\w+\\s+test_', text, re.M))\n    m = re.search(r'scan-assembler-times \\{[^}]*\\}\\s*(\\d+)', text)\n    scan_count = int(m.group(1)) if m else None\n    print(p, 'functions', func_count, 'scan', scan_count, 'match', func_count==scan_count)\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\nroot = Path('gcc/testsuite/gcc.target/riscv/rvv/base/zvfofp8min-testsuite')\nfor p in sorted(root.rglob('vfncvt.c')):\n    text = p.read_text()\n    func_count = len(re.findall(r'^\\w+\\s+test_', text, re.M))\n    m = re.search(r'scan-assembler-times \\{[^}]*\\}\\s*(\\d+)', text)\n    scan_count = int(m.group(1)) if m else None\n    print(p, 'functions', func_count, 'scan', scan_count, 'match', func_count==scan_count)\nPY"], decision="allow")
