prefix_rule(pattern=["git", "add", "gcc/config/riscv/riscv-v.cc", "gcc/config/riscv/riscv-vector-builtins-bases.cc", "gcc/config/riscv/riscv-vsetvl.cc", "gcc/config/riscv/riscv-vsetvl.def", "gcc/config/riscv/vector-float8.md", "gcc/config/riscv/vector.md"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "git commit -F - <<'EOF'\nRISC-V: Track FP8 altfmt in vsetvl\n\ngcc/ChangeLog:\n\n\t* config/riscv/vector.md (altfmt): New attribute.\n\t(@vsetvl<mode>, vsetvl_vtype_change_only): Add altfmt operand and\n\temit e%sewalt when requested.\n\t(@vsetvl_discard_result<mode>, @vsetvl<mode>_volatile): Likewise.\n\t(@vsetvl<mode>_no_side_effects, *vsetvldi_no_side_effects_si_extend):\n\tCarry altfmt through attributes.\n\t* config/riscv/vector-float8.md (altfmt_kind): New attribute.\n\t(@pred_extend_<altfmt_base>_to_<mode>): Set altfmt.\n\t(@pred_trunc_<mode>_to_<altfmt_sat>,\n\t@pred_quad_trunc_<mode>_to_<altfmt_sat>): Likewise.\n\t* config/riscv/riscv-vsetvl.def (DEF_ALTFMT_RULE): New macro.\n\tAdd altfmt fusion rules.\n\t* config/riscv/riscv-vsetvl.cc (altfmt_to_str, get_altfmt): New helpers.\n\t(demand_flags, altfmt_demand_type): Add altfmt demand tracking.\n\t(vsetvl_info): Track altfmt and its demand.\n\t(normalize_demand, parse_insn, get_vsetvl_pat, dump, operator==):\n\tHandle altfmt.\n\t(demand_system): Add altfmt compatibility, availability, and merge.\n\t(preds_all_same_avl_and_ratio_p): Check altfmt availability.\n\t* config/riscv/riscv-v.cc (emit_hard_vlmax_vsetvl,\n\tgen_no_side_effects_vsetvl_rtx): Pass ALTFMT_NONE.\n\t* config/riscv/riscv-vector-builtins-bases.cc: Include insn-attr.h.\n\t(vsetvl::expand): Pass ALTFMT_NONE.\nEOF"], decision="allow")
prefix_rule(pattern=["python3", "contrib/gcc-changelog/git_check_commit.py", "-v", "-p", "HEAD"], decision="allow")
prefix_rule(pattern=["git", "add", "gcc/config/riscv/vector.md", "gcc/config/riscv/riscv-v.cc", "gcc/config/riscv/riscv-vsetvl.cc", "gcc/config/riscv/riscv-vector-builtins-bases.cc"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "git commit -F - <<'EOF'\nRISC-V: Plumb altfmt through vsetvl patterns\n\ngcc/ChangeLog:\n\n\t* config/riscv/vector.md (altfmt): New attribute.\n\t(@vsetvl<mode>, vsetvl_vtype_change_only): Add altfmt operand and\n\temit e%sewalt when requested.\n\t(@vsetvl_discard_result<mode>, @vsetvl<mode>_volatile): Likewise.\n\t(@vsetvl<mode>_no_side_effects, *vsetvldi_no_side_effects_si_extend):\n\tCarry altfmt through attributes.\n\t* config/riscv/riscv-v.cc (emit_hard_vlmax_vsetvl,\n\tgen_no_side_effects_vsetvl_rtx): Pass ALTFMT_NONE.\n\t* config/riscv/riscv-vsetvl.cc (get_vsetvl_pat): Pass default altfmt.\n\t* config/riscv/riscv-vector-builtins-bases.cc: Include insn-attr.h.\n\t(vsetvl::expand): Add ALTFMT_NONE operand.\nEOF"], decision="allow")
prefix_rule(pattern=["git", "add", "gcc/config/riscv/vector.md"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "git commit -F - <<'EOF'\nRISC-V: Fix altfmt vsetvl output template\n\ngcc/ChangeLog:\n\n\t* config/riscv/vector.md (@vsetvl<mode>, vsetvl_vtype_change_only,\n\t@vsetvl_discard_result<mode>, @vsetvl<mode>_volatile): Rewrite the\n\toutput template to avoid stray backslashes in generated code.\nEOF"], decision="allow")
